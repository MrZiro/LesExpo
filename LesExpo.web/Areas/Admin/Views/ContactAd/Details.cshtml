@model Contact

@{
    ViewData["Title"] = "İletişim Detayları";
    var langText = Model.Language == "tr" ? "Türkçe" : "İngilizce";
    var langIcon = Model.Language == "tr" ? "bi-flag" : "bi-flag-fill";
    var badgeClass = Model.Language == "tr" ? "bg-primary" : "bg-info";
}

<!-- Page Header -->
<div class="page-header p-4">
    <div class="row align-items-center">
        <div class="col-md-8">
            <h1 class="mb-1 fw-bold">
                <i class="bi bi-envelope-open me-3"></i>Mesaj Detayları
            </h1>
            <p class="mb-0 opacity-75">@Model.CreatedAt.ToString("dd MMMM yyyy, HH:mm") tarihinde alınan mesaj</p>
        </div>
        <div class="col-md-4 text-end">
            <span class="lang-badge @(Model.Language == "tr" ? "badge-tr" : "badge-en") text-white">
                <i class="bi @langIcon"></i>
                @langText
            </span>
        </div>
    </div>
</div>

<!-- Contact Details -->
<div class="contact-card p-4">
    <div class="row">
        <div class="col-lg-6">
            <!-- Sender Information -->
            <div class="info-item">
                <div class="info-label">
                    <i class="bi bi-person me-1"></i>Gönderen
                </div>
                <div class="info-value">@Model.Name</div>
            </div>

            <!-- Email -->
            <div class="info-item">
                <div class="info-label">
                    <i class="bi bi-envelope me-1"></i>E-posta Adresi
                </div>
                <div class="info-value">
                    <a href="mailto:@Model.Email" class="email-link">@Model.Email</a>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <!-- Subject -->
            <div class="info-item">
                <div class="info-label">
                    <i class="bi bi-chat-square-text me-1"></i>Konu
                </div>
                <div class="info-value">@Model.Subject</div>
            </div>

            <!-- Date -->
            <div class="info-item">
                <div class="info-label">
                    <i class="bi bi-calendar-event me-1"></i>Alınma Tarihi
                </div>
                <div class="info-value">@Model.CreatedAt.ToString("dd MMMM yyyy")</div>
                <small class="text-muted">@Model.CreatedAt.ToString("HH:mm")</small>
            </div>
        </div>
    </div>

    <!-- Message Content -->
    <div class="message-card">
        <div class="info-label mb-3">
            <i class="bi bi-chat-left-quote me-1"></i>Mesaj İçeriği
        </div>
        <div style="white-space: pre-wrap; line-height: 1.6; color: #2d3748; font-size: 1.05rem;">@Model.Message</div>
    </div>

    <!-- Action Buttons -->
    <div class="action-buttons text-center">
        <a asp-controller="ContactAd" asp-action="Index" class="btn btn-custom btn-back me-3">
            <i class="bi bi-arrow-left"></i>
            Listeye Dön
        </a>
        <a href="mailto:@Model.Email?subject=Re: @Model.Subject" class="btn btn-custom btn-reply">
            <i class="bi bi-reply"></i>
            E-posta ile Yanıtla
        </a>
    </div>
</div> 