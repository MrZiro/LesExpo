@model LoginVM
@{
    ViewData["Title"] = "Giriş";
    Layout = "";
}
<!doctype html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BursaFuarMerkezi.web</title>
    @* <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" /> *@
    @* <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" /> *@
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/BursaFuarMerkezi.web.styles.css" asp-append-version="true" />
    <!-- Bootstrap CSS -->

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/css/toastr.min.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@24,400,0,0" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:ital,wght@0,200..1000;1,200..1000&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/admin/styles/loader.css">
    <link href="~/admin/styles/style.css" rel="stylesheet" />
</head>
<body>
    <div class="container pt-5">
        <div class="card shadow border">
            <div class="card-header bg-success bg-gradient ml-0 py-4">
                <div class="row">
                    <div class="col-12 text-center">
                        <h2 class="py-2 text-white">Giriş</h2>
                    </div>
                </div>
            </div>
            <div class="card-body p-4">
                <div class="row">
                    <div class="col-md-12">
                        <section>
                            <form method="post">
                                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                                <input asp-for="RedirectUrl"  hidden />
                                <div class="form-floating mb-3">
                                    <input asp-for="Email" class="form-control" aria-required="true" />
                                    <label asp-for="Email" class="form-label">E-posta</label>
                                    <span asp-validation-for="Email" class="text-danger"></span>
                                </div>
                                <div class="form-floating mb-3">
                                    <input asp-for="Password" class="form-control" aria-required="true" />
                                    <label asp-for="Password" class="form-label">Şifre</label>
                                    <span asp-validation-for="Password" class="text-danger"></span>
                                </div>
                                <div>
                                    <button type="submit" class="w-100 btn btn-lg btn-outline-success">Giriş Yap</button>
                                </div>
                                <div class="d-flex justify-content-between pt-2">
                                    <p>
                                        <a>Şifremi unuttum?</a>
                                    </p>
                                    <p>
                                        <a>Yeni kullanıcı olarak kaydol</a>
                                    </p>
                                </div>
                            </form>
                        </section>
                    </div>

                </div>
            </div>
        </div>
    </div>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }
</body>
</html>
