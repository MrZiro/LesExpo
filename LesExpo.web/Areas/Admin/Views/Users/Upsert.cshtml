@model RegisterVM

@section Styles {
}

<!-- Page Header -->
<div class="page-header p-4">
    <div class="row align-items-center">
        <div class="col-md-8">
            <h1 class="mb-1 fw-bold">
                <i class="bi bi-@(Model.Id == null ? "person-plus" : "person-gear") me-3"></i>Kullanıcı @(Model.Id == null ? "Oluştur" : "Güncelle")
            </h1>
            <p class="mb-0 opacity-75">Sistem kullanıcısını @(Model.Id == null ? "oluşturun" : "güncelleyin")</p>
        </div>
        <div class="col-md-4 text-end">
            <div class="stats-card p-3 text-center">
                <h5 class="mb-1">@(Model.Id == null ? "Yeni Kayıt" : "Düzenleme")</h5>
                <h3 class="mb-0">Kullanıcı</h3>
            </div>
        </div>
    </div>
</div>

<!-- Form Content -->
<div class="contact-card p-4">
    <form method="post" asp-action="Upsert">
        <input asp-for="Id" hidden />
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="row">
            <div class="col-md-8">
                <!-- Basic Information Card -->
                <div class="info-item">
                    <div class="info-label mb-3">
                        <i class="bi bi-person-badge me-1"></i>Temel Bilgiler
                    </div>
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">İsim</label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">E-posta</label>
                        <input asp-for="Email" class="form-control" type="email" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <!-- Security Settings Card -->
                <div class="info-item">
                    <div class="info-label mb-3">
                        <i class="bi bi-shield-lock me-1"></i>Güvenlik Ayarları
                    </div>
                    <div class="mb-3">
                        <label asp-for="Password" class="form-label">
                            @(Model.Id == null ? "Şifre" : "Yeni Şifre")
                        </label>
                        <input asp-for="Password" class="form-control" type="password" required="@(Model.Id == null)" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                        @if (Model.Id != null)
                        {
                            <div class="form-text">Değiştirmek istemiyorsanız boş bırakın</div>
                        }
                    </div>

                    @if (Model.Id == null)
                    {
                        <div class="mb-3">
                            <label asp-for="ConfirmPassword" class="form-label">Şifreyi Onayla</label>
                            <input asp-for="ConfirmPassword" class="form-control" type="password" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>
                    }

                    <div class="mb-3">
                        <label asp-for="Role" class="form-label">Rol</label>
                        <select asp-for="Role" asp-items="Model.RoleList" class="form-select">
                            <option disabled selected>--Rol Seçin--</option>
                        </select>
                        <span asp-validation-for="Role" class="text-danger"></span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Action Buttons -->
        <div class="action-buttons text-center">
            <a asp-action="Index" class="btn btn-custom btn-back me-3">
                <i class="bi bi-arrow-left"></i>
                Listeye Dön
            </a>
            <button type="submit" class="btn btn-custom btn-reply">
                <i class="bi bi-@(Model.Id == null ? "person-plus" : "person-check")"></i>
                @(Model.Id == null ? "Kullanıcı Oluştur" : "Kullanıcı Güncelle")
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        $(document).ready(function() {
            if ('@Model.Id' != '') {
                $('#Password').removeAttr('required');
                $('#ConfirmPassword').removeAttr('required');
            }
        });
    </script>
}