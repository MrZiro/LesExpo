@{
    ViewBag.Title = "Dashboard";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
<style>
    body {
        font-family: 'Segoe UI', sans-serif;
        background: #f4f6f8;
        margin: 0;
        padding: 20px;
    }

    .dashboard-container {
        max-width: 1200px;
        margin: auto;
    }

    .cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 20px;
        margin-bottom: 40px;
    }

    .card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        padding: 20px;
        display: flex;
        align-items: center;
        gap: 15px;
        transition: 0.3s ease;
    }

        .card:hover {
            transform: translateY(-3px);
        }

        .card i {
            font-size: 2rem;
            color: #4a90e2;
        }

        .card .info {
            flex: 1;
        }

    .info h3 {
        margin: 0;
        font-size: 1.2rem;
        color: #333;
    }

    .info p {
        margin: 5px 0 0;
        color: #666;
    }

    .charts {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 30px;
    }

    .chart-box {
        background: white;
        padding: 20px;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    }

    .bar-chart .bar {
        background: #4a90e2;
        height: 20px;
        margin: 8px 0;
        border-radius: 5px;
        transition: width 0.3s;
    }

    .bar-label {
        font-size: 0.9rem;
        margin-bottom: 4px;
        color: #444;
    }

    .pie-chart {
        width: 160px;
        height: 160px;
        border-radius: 50%;
        background-image: conic-gradient( #4a90e2 0% 40%, #50e3c2 40% 70%, #f5a623 70% 100% );
        margin: auto;
    }

    .chart-title {
        text-align: center;
        margin-top: 15px;
        font-weight: bold;
        color: #444;
    }
</style>

<div class="dashboard-container">
    <h2>Dashboard</h2>

    <div class="cards">
        <div class="card">
            <i class="fas fa-users"></i>
            <div class="info">
                <h3>1,250</h3>
                <p>Users</p>
            </div>
        </div>
        <div class="card">
            <i class="fas fa-pen-nib"></i>
            <div class="info">
                <h3>300</h3>
                <p>Blog Posts</p>
            </div>
        </div>
        <div class="card">
            <i class="fas fa-image"></i>
            <div class="info">
                <h3>120</h3>
                <p>Sliders</p>
            </div>
        </div>
        <div class="card">
            <i class="fas fa-layer-group"></i>
            <div class="info">
                <h3>45</h3>
                <p>Page Types</p>
            </div>
        </div>
    </div>

    <div class="charts">
        <div class="chart-box bar-chart">
            <h3 class="chart-title">Content Types Usage</h3>
            <div>
                <div class="bar-label">Blog</div>
                <div class="bar" style="width: 70%;"></div>
            </div>
            <div>
                <div class="bar-label">Slider</div>
                <div class="bar" style="width: 50%;"></div>
            </div>
            <div>
                <div class="bar-label">Users</div>
                <div class="bar" style="width: 80%;"></div>
            </div>
            <div>
                <div class="bar-label">Pages</div>
                <div class="bar" style="width: 60%;"></div>
            </div>
        </div>

        <div class="chart-box">
            <h3 class="chart-title">Page Distribution</h3>
            <div class="pie-chart"></div>
        </div>
    </div>
</div>
