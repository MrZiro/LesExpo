@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<!-- Include Chart.js -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.9.1/chart.min.js"></script>
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">

<style>
    .dashboard-card {
        background: white;
        border-radius: 10px;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        padding: 20px;
        margin-bottom: 20px;
        transition: transform 0.2s;
    }
    
    .dashboard-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 15px rgba(0, 0, 0, 0.15);
    }
    
    .stat-card {
        text-align: center;
        border-left: 4px solid;
    }
    
    .stat-card.users { border-left-color: #007bff; }
    .stat-card.blogs { border-left-color: #28a745; }
    .stat-card.sliders { border-left-color: #ffc107; }
    .stat-card.pages { border-left-color: #dc3545; }
    .stat-card.content { border-left-color: #6f42c1; }
    
    .stat-number {
        font-size: 2.5rem;
        font-weight: bold;
        margin-bottom: 10px;
    }
    
    .stat-label {
        color: #6c757d;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 1px;
    }
    
    .stat-icon {
        font-size: 2rem;
        opacity: 0.7;
        margin-bottom: 10px;
    }
    
    .users .stat-number, .users .stat-icon { color: #007bff; }
    .blogs .stat-number, .blogs .stat-icon { color: #28a745; }
    .sliders .stat-number, .sliders .stat-icon { color: #ffc107; }
    .pages .stat-number, .pages .stat-icon { color: #dc3545; }
    .content .stat-number, .content .stat-icon { color: #6f42c1; }
    
    .chart-container {
        position: relative;
        height: 300px;
        margin: 20px 0;
    }
    
    .activity-item {
        display: flex;
        align-items: center;
        padding: 15px;
        border-bottom: 1px solid #eee;
        transition: background-color 0.2s;
    }
    
    .activity-item:hover {
        background-color: #f8f9fa;
    }
    
    .activity-item:last-child {
        border-bottom: none;
    }
    
    .activity-icon {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-right: 15px;
        color: white;
    }
    
    .activity-icon.blog { background-color: #28a745; }
    .activity-icon.slider { background-color: #ffc107; }
    .activity-icon.user { background-color: #007bff; }
    .activity-icon.page { background-color: #dc3545; }
    .activity-icon.content { background-color: #6f42c1; }
    
    .activity-content {
        flex: 1;
    }
    
    .activity-title {
        font-weight: 600;
        margin-bottom: 5px;
    }
    
    .activity-meta {
        font-size: 0.85rem;
        color: #6c757d;
    }
    
    .page-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 30px 0;
        margin-bottom: 30px;
        border-radius: 10px;
    }
    
    .page-title {
        font-size: 2.5rem;
        font-weight: 300;
        margin-bottom: 10px;
    }
    
    .page-subtitle {
        opacity: 0.9;
        font-size: 1.1rem;
    }
</style>

<div class="container-fluid">
    <!-- Page Header -->
    <div class="page-header text-center">
        <h1 class="page-title">
            <i class="fas fa-tachometer-alt me-3"></i>
            Dashboard
        </h1>
        <p class="page-subtitle text-white">Sistem istatistikleri ve genel bakış</p>
    </div>

    <!-- Statistics Cards -->
    <div class="row mb-4">
        <div class=" mb-3">
            <div class="dashboard-card stat-card users">
                <div class="stat-icon">
                    <i class="fas fa-users"></i>
                </div>
                <div class="stat-number">@Model.TotalUsers</div>
                <div class="stat-label">Kullanıcılar</div>
            </div>
        </div>
        <div class=" mb-3">
            <div class="dashboard-card stat-card blogs">
                <div class="stat-icon">
                    <i class="fas fa-blog"></i>
                </div>
                <div class="stat-number">@Model.TotalBlogs</div>
                <div class="stat-label">Blog Yazıları</div>
            </div>
        </div>
        <div class=" mb-3">
            <div class="dashboard-card stat-card sliders">
                <div class="stat-icon">
                    <i class="fas fa-images"></i>
                </div>
                <div class="stat-number">@Model.TotalSliders</div>
                <div class="stat-label">Slider</div>
            </div>
        </div>
        <div class=" mb-3">
            <div class="dashboard-card stat-card pages">
                <div class="stat-icon">
                    <i class="fas fa-file-alt"></i>
                </div>
                <div class="stat-number">@Model.TotalPages</div>
                <div class="stat-label">Sayfalar</div>
            </div>
        </div>
        <div class=" mb-3">
            <div class="dashboard-card stat-card content">
                <div class="stat-icon">
                    <i class="fas fa-layer-group"></i>
                </div>
                <div class="stat-number">@Model.TotalIcerikTuru</div>
                <div class="stat-label">İçerik Türü</div>
            </div>
        </div>
    </div>

    <!-- Charts Row -->
    <div class="row">
        <!-- Monthly Blog Stats -->
        <div class="col-lg-6 mb-4">
            <div class="dashboard-card">
                <h5 class="mb-3">
                    <i class="fas fa-chart-line me-2"></i>
                    Aylık Blog İstatistikleri
                </h5>
                <div class="chart-container">
                    <canvas id="blogChart"></canvas>
                </div>
            </div>
        </div>

        <!-- Monthly User Stats -->
        <div class="col-lg-6 mb-4">
            <div class="dashboard-card">
                <h5 class="mb-3">
                    <i class="fas fa-chart-area me-2"></i>
                    Aylık Kullanıcı İstatistikleri
                </h5>
                <div class="chart-container">
                    <canvas id="userChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Category Distribution -->
        <div class="col-lg-4 mb-4">
            <div class="dashboard-card">
                <h5 class="mb-3">
                    <i class="fas fa-chart-pie me-2"></i>
                    Kategori Dağılımı
                </h5>
                <div class="chart-container">
                    <canvas id="categoryChart"></canvas>
                </div>
            </div>
        </div>

        <!-- Recent Activities -->
        <div class="col-lg-8 mb-4">
            <div class="dashboard-card">
                <h5 class="mb-3">
                    <i class="fas fa-history me-2"></i>
                    Son Aktiviteler
                </h5>
                <div class="activity-list">
                    @foreach (var activity in Model.RecentActivities)
                    {
                        <div class="activity-item">
                            <div class="activity-icon @activity.Type">
                                @switch (activity.Type)
                                {
                                    case "blog":
                                        <i class="fas fa-blog"></i>
                                        break;
                                    case "slider":
                                        <i class="fas fa-images"></i>
                                        break;
                                    case "user":
                                        <i class="fas fa-user"></i>
                                        break;
                                    case "page":
                                        <i class="fas fa-file-alt"></i>
                                        break;
                                    case "content":
                                        <i class="fas fa-layer-group"></i>
                                        break;
                                }
                            </div>
                            <div class="activity-content">
                                <div class="activity-title">@activity.Action</div>
                                <div class="activity-meta">
                                    @activity.User • @activity.Date.ToString("dd.MM.yyyy HH:mm")
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Blog Chart
    const blogCtx = document.getElementById('blogChart').getContext('2d');
    const blogChart = new Chart(blogCtx, {
        type: 'line',
        data: {
            labels: [@Html.Raw(string.Join(",", Model.MonthlyBlogStats.Select(x => $"'{x.Month}'")))],
            datasets: [{
                label: 'Blog Yazıları',
                data: [@string.Join(",", Model.MonthlyBlogStats.Select(x => x.Count))],
                borderColor: '#28a745',
                backgroundColor: 'rgba(40, 167, 69, 0.1)',
                borderWidth: 3,
                fill: true,
                tension: 0.4
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: {
                    display: false
                }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    grid: {
                        color: 'rgba(0,0,0,0.1)'
                    }
                },
                x: {
                    grid: {
                        display: false
                    }
                }
            }
        }
    });

    // User Chart
    const userCtx = document.getElementById('userChart').getContext('2d');
    const userChart = new Chart(userCtx, {
        type: 'bar',
        data: {
            labels: [@Html.Raw(string.Join(",", Model.MonthlyUserStats.Select(x => $"'{x.Month}'")))],
            datasets: [{
                label: 'Yeni Kullanıcılar',
                data: [@string.Join(",", Model.MonthlyUserStats.Select(x => x.Count))],
                backgroundColor: 'rgba(0, 123, 255, 0.8)',
                borderColor: '#007bff',
                borderWidth: 1,
                borderRadius: 5
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: {
                    display: false
                }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    grid: {
                        color: 'rgba(0,0,0,0.1)'
                    }
                },
                x: {
                    grid: {
                        display: false
                    }
                }
            }
        }
    });

    // Category Chart
    const categoryCtx = document.getElementById('categoryChart').getContext('2d');
    const categoryChart = new Chart(categoryCtx, {
        type: 'doughnut',
        data: {
            labels: [@Html.Raw(string.Join(",", Model.CategoryStats.Select(x => $"'{x.Category}'")))],
            datasets: [{
                data: [@string.Join(",", Model.CategoryStats.Select(x => x.Count))],
                backgroundColor: [@Html.Raw(string.Join(",", Model.CategoryStats.Select(x => $"'{x.Color}'")))],
                borderWidth: 0
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: {
                    position: 'bottom',
                    labels: {
                        padding: 20,
                        usePointStyle: true
                    }
                }
            }
        }
    });
</script>