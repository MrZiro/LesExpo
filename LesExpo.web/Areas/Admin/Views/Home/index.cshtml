@model DashboardVM
@{
    ViewData["Title"] = "Dashboard";
}

@section Styles{
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
<link rel="stylesheet" href="~/admin/styles/Home.css" />
}

<div class="dashboard-container">
    <!-- Header -->
    <div class="dashboard-header loading">
        <button class="refresh-btn" onclick="refreshDashboard()" title="Verileri Yenile">
            <i class="fas fa-sync-alt"></i>
        </button>
        <div class="system-info" id="systemInfo">
            <span class="status-indicator"></span>
            <span id="serverTime">Yükleniyor...</span>
        </div>
        <h1><i class="fas fa-tachometer-alt"></i> Dashboard</h1>
        <p>Sistem istatistikleri ve genel bakış</p>
    </div>

    <!-- System Information -->
    <div class="main-con loading mb-5" style="animation-delay: 0.1s">
        <div class="chart-title mb-3">
            <i class="fas fa-server" style="color: var(--ca-primary);"></i>
            Sistem Bilgileri
        </div>
        <div class="system-info-grid" id="systemInfoGrid">
            <!-- Populated by JavaScript -->
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="stats-grid">
        <div class="stat-card blogs loading" style="animation-delay: 0.2s" onclick="window.location.href='@Url.Action("Index", "Blog", new { area = "Admin" })'">
            <div class="stat-icon"><i class="fas fa-blog"></i></div>
            <div class="stat-number" data-target="@Model.TotalBlogs">0</div>
            <div class="stat-label">Blog Yazıları</div>
        </div>

        <div class="stat-card pages loading" style="animation-delay: 0.4s" onclick="window.location.href='@Url.Action("Index", "ContactAd", new { area = "Admin" })'">
            <div class="stat-icon"><i class="fas fa-envelope"></i></div>
            <div class="stat-number" data-target="@Model.TotalContacts">0</div>
            <div class="stat-label">İletişim</div>
        </div>

        <div class="stat-card content loading" style="animation-delay: 0.5s" onclick="window.location.href='@Url.Action("Index", "ContentType", new { area = "Admin" })'">
            <div class="stat-icon"><i class="fas fa-layer-group"></i></div>
            <div class="stat-number" data-target="@Model.TotalIcerikTuru">0</div>
            <div class="stat-label">İçerik Türü</div>
        </div>

        <div class="stat-card tickets loading" style="animation-delay: 0.6s" onclick="window.location.href='@Url.Action("Index", "TicketAd", new { area = "Admin" })'">
            <div class="stat-icon"><i class="fas fa-ticket-alt"></i></div>
            <div class="stat-number" data-target="@Model.TotalTickets">0</div>
            <div class="stat-label">Bilet Başvuruları</div>
        </div>

        <div class="stat-card registrations loading" style="animation-delay: 0.7s" onclick="window.location.href='@Url.Action("Index", "RegistrationAd", new { area = "Admin" })'">
            <div class="stat-icon"><i class="fas fa-clipboard-list"></i></div>
            <div class="stat-number" data-target="@Model.TotalRegistrations">0</div>
            <div class="stat-label">Fuar Kayıtları</div>
        </div>
    </div>

    <!-- Charts -->
    <div class="charts-grid">
        <!-- Blog Stats Chart -->
        <div class="main-con loading" style="animation-delay: 0.7s">
            <h3 class="chart-title">
                <i class="fas fa-chart-line" style="color: var(--ca-primary);"></i>
                Aylık Blog İstatistikleri
            </h3>
            <div class="line-chart" id="blogChart">
                @if (Model.MonthlyBlogStats != null && Model.MonthlyBlogStats.Any())
                {
                    var maxBlog = Model.MonthlyBlogStats.Max(x => x.Count);
                    maxBlog = maxBlog == 0 ? 1 : maxBlog; // Prevent division by zero
                    
                    @foreach (var stat in Model.MonthlyBlogStats)
                    {
                        var height = (stat.Count * 150 / maxBlog);
                        <div class="chart-bar" style="--height: @(height)px; height: @(height)px;" data-value="@stat.Count"></div>
                    }
                }
                else
                {
                    <div style="text-align: center; color: var(--ca-text-muted); padding: 50px;">
                        <i class="fas fa-chart-line" style="font-size: 3rem; margin-bottom: 20px; opacity: 0.3;"></i>
                        <p>Henüz blog verisi bulunmuyor</p>
                    </div>
                }
            </div>
            @if (Model.MonthlyBlogStats != null && Model.MonthlyBlogStats.Any())
            {
                <div class="chart-labels">
                    @foreach (var stat in Model.MonthlyBlogStats)
                    {
                        <div class="chart-label">@stat.Month</div>
                    }
                </div>
            }
        </div>
        
        <!-- Category Distribution -->
        <div class="main-con loading" style="animation-delay: 0.8s">
            <h3 class="chart-title">
                <i class="fas fa-chart-pie" style="color: var(--ca-success);"></i>
                Kategori Dağılımı
            </h3>
            @if (Model.CategoryStats != null && Model.CategoryStats.Any() && Model.CategoryStats.Sum(c => c.Count) > 0)
            {
                var totalCount = Model.CategoryStats.Sum(c => c.Count);
                var currentAngle = 0.0;
                var gradientParts = new List<string>();
                 
                foreach (var category in Model.CategoryStats.Where(c => c.Count > 0))
                {
                    var percentage = (double)category.Count / totalCount * 100;
                    var angle = percentage * 3.6;
                    gradientParts.Add($"{category.Color} {currentAngle}deg {currentAngle + angle}deg");
                    currentAngle += angle;
                }
                var gradientStyle = $"conic-gradient(from 0deg, {string.Join(", ", gradientParts)})";
                <div class="pie-chart" style="background: @gradientStyle;"></div>
                <div class="pie-legend">
                    @foreach (var category in Model.CategoryStats.Where(c => c.Count > 0))
                    {
                        <div class="legend-item">
                            <div class="legend-color" style="background-color: @category.Color;"></div>
                            <span>@category.Category (@category.Count)</span>
                        </div>
                    }
                </div>
            }
            else
            {
                <div style="text-align: center; color: var(--ca-text-muted); padding: 50px;">
                    <i class="fas fa-chart-pie" style="font-size: 3rem; margin-bottom: 20px; opacity: 0.3;"></i>
                    <p>Henüz kategori verisi bulunmuyor</p>
                </div>
            }
        </div>
        
        <!-- Ticket & Registration Stats -->
        <div class="main-con loading" style="animation-delay: 0.9s">
            <h3 class="chart-title">
                <i class="fas fa-chart-bar" style="color: var(--ca-accent);"></i>
                Aylık Başvuru İstatistikleri
            </h3>
            <div class="dual-chart-container">
                @if (Model.MonthlyTicketStats != null && Model.MonthlyRegistrationStats != null && 
                     (Model.MonthlyTicketStats.Any(t => t.Count > 0) || Model.MonthlyRegistrationStats.Any(r => r.Count > 0)))
                {
                    var maxTicket = Model.MonthlyTicketStats.Max(x => x.Count);
                    var maxReg = Model.MonthlyRegistrationStats.Max(x => x.Count);
                    var maxCount = Math.Max(maxTicket, maxReg);
                    maxCount = maxCount == 0 ? 1 : maxCount;
                    
                    <div class="chart-legend-custom">
                        <span><i class="fas fa-square" style="color: var(--ca-accent);"></i> Bilet</span>
                        <span><i class="fas fa-square" style="color: var(--ca-info);"></i> Kayıt</span>
                    </div>
                    <div class="dual-chart">
                        @for (int i = 0; i < Model.MonthlyTicketStats.Count; i++)
                        {
                            var ticketHeight = (Model.MonthlyTicketStats[i].Count * 110 / maxCount);
                            var regHeight = (Model.MonthlyRegistrationStats[i].Count * 110 / maxCount);
                            <div class="chart-group">
                                <div class="chart-bar" style="--height: @(ticketHeight)px; height: @(ticketHeight)px; background: var(--ca-accent); width: 20px;" data-value="@Model.MonthlyTicketStats[i].Count" title="Bilet: @Model.MonthlyTicketStats[i].Count"></div>
                                <div class="chart-bar" style="--height: @(regHeight)px; height: @(regHeight)px; background: var(--ca-info); width: 20px;" data-value="@Model.MonthlyRegistrationStats[i].Count" title="Kayıt: @Model.MonthlyRegistrationStats[i].Count"></div>
                            </div>
                        }
                    </div>
                    <div class="chart-labels">
                        @foreach (var stat in Model.MonthlyTicketStats)
                        {
                            <div class="chart-label">@stat.Month</div>
                        }
                    </div>
                }
                else
                {
                    <div style="text-align: center; color: var(--ca-text-muted); padding: 40px;">
                        <i class="fas fa-chart-bar" style="font-size: 2.5rem; margin-bottom: 16px; opacity: 0.3;"></i>
                        <p>Henüz başvuru verisi bulunmuyor</p>
                    </div>
                }
            </div>
        </div>
        
        <!-- Country Distribution -->
        <div class="main-con loading" style="animation-delay: 1s">
            <h3 class="chart-title">
                <i class="fas fa-globe" style="color: var(--ca-danger);"></i>
                Ülke Dağılımı
            </h3>
            @if (Model.CountryStats != null && Model.CountryStats.Any() && Model.CountryStats.Sum(c => c.Count) > 0)
            {
                var totalCountryCount = Model.CountryStats.Sum(c => c.Count);
                var currentAngle = 0.0;
                var gradientParts = new List<string>();
                
                foreach (var country in Model.CountryStats.Where(c => c.Count > 0))
                {
                    var percentage = (double)country.Count / totalCountryCount * 100;
                    var angle = percentage * 3.6;
                    gradientParts.Add($"{country.Color} {currentAngle}deg {currentAngle + angle}deg");
                    currentAngle += angle;
                }
                var gradientStyle = $"conic-gradient(from 0deg, {string.Join(", ", gradientParts)})";
                
                <!-- Country distribution chart -->
                <div class="pie-chart-fallback">
                    @foreach (var country in Model.CountryStats.Where(c => c.Count > 0))
                    {
                        var percentage = (double)country.Count / totalCountryCount * 100;
                        <div class="chart-bar-item">
                            <div class="chart-bar-color" style="background-color: @country.Color;"></div>
                            <span style="font-weight: 600; font-size: 13px; min-width: 80px;">@country.Category</span>
                            <div class="chart-bar-bg">
                                <div class="chart-bar-fill" style="background-color: @country.Color; width: @percentage.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)%;"></div>
                            </div>
                            <span class="chart-bar-label">@country.Count (@percentage.ToString("F1")%)</span>
                        </div>
                    }
                </div>
            }
            else
            {
                <div style="text-align: center; color: var(--ca-text-muted); padding: 50px;">
                    <i class="fas fa-globe" style="font-size: 3rem; margin-bottom: 20px; opacity: 0.3;"></i>
                    <p>Henüz ülke verisi bulunmuyor</p>
                </div>
            }
        </div>
        
        <!-- Sector Distribution -->
        <div class="main-con loading" style="animation-delay: 1.1s">
            <h3 class="chart-title">
                <i class="fas fa-industry" style="color: var(--ca-warning);"></i>
                Sektör Dağılımı
            </h3>
            @if (Model.SectorStats != null && Model.SectorStats.Any() && Model.SectorStats.Sum(s => s.Count) > 0)
            {
                var totalSectorCount = Model.SectorStats.Sum(s => s.Count);
                var currentAngle = 0.0;
                var gradientParts = new List<string>();
                
                foreach (var sector in Model.SectorStats.Where(s => s.Count > 0))
                {
                    var percentage = (double)sector.Count / totalSectorCount * 100;
                    var angle = percentage * 3.6;
                    gradientParts.Add($"{sector.Color} {currentAngle}deg {currentAngle + angle}deg");
                    currentAngle += angle;
                }
                var gradientStyle = $"conic-gradient(from 0deg, {string.Join(", ", gradientParts)})";
                
                <!-- Sector distribution chart -->
                <div class="pie-chart-fallback">
                    @foreach (var sector in Model.SectorStats.Where(s => s.Count > 0))
                    {
                        var percentage = (double)sector.Count / totalSectorCount * 100;
                        <div class="chart-bar-item">
                            <div class="chart-bar-color" style="background-color: @sector.Color;"></div>
                            <span style="font-weight: 600; font-size: 13px; min-width: 80px;">@sector.Category</span>
                            <div class="chart-bar-bg">
                                <div class="chart-bar-fill" style="background-color: @sector.Color; width: @percentage.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)%;"></div>
                            </div>
                            <span class="chart-bar-label">@sector.Count (@percentage.ToString("F1")%)</span>
                        </div>
                    }
                </div>

            }
            else
            {
                <div style="text-align: center; color: var(--ca-text-muted); padding: 50px;">
                    <i class="fas fa-industry" style="font-size: 3rem; margin-bottom: 20px; opacity: 0.3;"></i>
                    <p>Henüz sektör verisi bulunmuyor</p>
                </div>
            }
        </div>
    </div>

    <!-- Recent Activities -->
    <div class="main-con loading" style="animation-delay: 1.2s">
        <h3 class="chart-title">
            <i class="fas fa-history" style="color: var(--ca-text-muted);"></i>
            Son Aktiviteler
        </h3>
        @if (Model.RecentActivities != null && Model.RecentActivities.Any())
        {
            @foreach (var activity in Model.RecentActivities)
            {
                <div class="activity-item @activity.Type">
                    <div class="activity-icon">
                        @switch (activity.Type)
                        {
                            case "blog": <i class="fas fa-blog"></i>; break;
                            case "slider": <i class="fas fa-images"></i>; break;
                            case "ticket": <i class="fas fa-ticket-alt"></i>; break;
                            case "registration": <i class="fas fa-clipboard-list"></i>; break;
                            case "contact": <i class="fas fa-envelope"></i>; break;
                            case "content": <i class="fas fa-layer-group"></i>; break;
                        }
                    </div>
                    <div class="activity-content">
                        <div class="activity-title">@activity.Action</div>
                        <div class="activity-meta">
                            <i class="fas fa-user"></i>
                            <span>@activity.User</span>
                            <div class="activity-time">@activity.Date.ToString("dd.MM.yyyy HH:mm")</div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div style="text-align: center; color: var(--ca-text-muted); padding: 50px;">
                <i class="fas fa-history" style="font-size: 3rem; margin-bottom: 20px; opacity: 0.3;"></i>
                <p>Henüz aktivite bulunmuyor</p>
            </div>
        }
    </div>
</div>

@section scripts{
    <script>
        // Pass URLs from server to client-side script
        window.getSystemInfoUrl = '@Url.Action("GetSystemInfo", "Home", new { area = "Admin" })';
        window.getDashboardStatsUrl = '@Url.Action("GetDashboardStats", "Home", new { area = "Admin" })';
    </script>
    <script src="~/admin/scripts/Home.js" defer></script>
}