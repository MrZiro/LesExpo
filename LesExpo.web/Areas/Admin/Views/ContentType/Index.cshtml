@model List<ContentType>
@{
    ViewData["Title"] = "Content Types";
}
@section Styles{
	<link href="~/lib/datatables.net-dt/css/datatables.datatables.min.css" rel="stylesheet" />
}

<div class="container">
    <div class="row pt-4 pb-3">
        <div class="col-6">
            <h2 class="text-primary">
                Content Types
            </h2>
        </div>
        <div class="col-6 text-end">
            <a asp-controller="ContentType" asp-action="Upsert" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Create New Content Type
            </a>
        </div>
    </div>

    <div class="table-container">
        <table id="tblData" class="table" style="width:100%">
            <thead>
                <!-- DataTable will populate headers -->
            </thead>
            <tbody>
                <!-- DataTable will populate data -->
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <partial name="_PartialReqScript" />

    <script>
        $(document).ready(() => {
            initializeDataTableWithOption('ContentType', [
                {
                    title: 'Name',
                    data: 'name',
                    width: '80%'
                },
            ]);
        });
    </script>
} 