@model ContentType

@{
    ViewData["Title"] = Model.Id == 0 ? "İçerik Türü Oluştur" : "İçerik Türü Düzenle";
}

@section Styles {
}

<!-- Page Header -->
<div class="page-header p-4 mb-4">
    <div class="row align-items-center">
        <div class="col-md-8">
            <h1 class="mb-1 fw-bold">
                <i class="bi bi-tags me-3"></i>İçerik Türü @(Model.Id == 0 ? "Oluştur" : "Güncelle")
            </h1>
            <p class="mb-0 opacity-75">Sitede kullanılacak içerik türünü @(Model.Id == 0 ? "oluşturun" : "güncelleyin")</p>
        </div>
        <div class="col-md-4 text-end">
            <div class="stats-card p-3 text-center">
                <h5 class="mb-1">@(Model.Id == 0 ? "Yeni Kayıt" : "Düzenleme")</h5>
            </div>
        </div>
    </div>
</div>

<!-- Form Card -->
<div class="contact-card p-4">
    <form method="post" asp-action="Upsert">
        <input asp-for="Id" hidden />
        <div asp-validation-summary="All" class="text-danger"></div>

        <div class="mb-3">
            <label asp-for="Name" class="form-label">İsim (TR)</label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="NameEn" class="form-label">İsim (EN)</label>
            <input asp-for="NameEn" class="form-control" />
            <span asp-validation-for="NameEn" class="text-danger"></span>
        </div>

        <div class="text-end mt-4">
            <a asp-controller="ContentType" asp-action="Index" class="btn btn-custom btn-back me-3">
                <i class="bi bi-arrow-left"></i>
                Listeye Dön
            </a>
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-save"></i> @(Model.Id == 0 ? "Oluştur" : "Güncelle")
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
} 