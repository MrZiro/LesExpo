@model List<Slider>
@{
    ViewData["Title"] = "Slider Yönetimi";
}

@section Styles {
    <link href="~/lib/datatables.net-dt/css/datatables.datatables.min.css" rel="stylesheet" />
    <link href="~/admin/styles/table.css" rel="stylesheet" />
}

<div class="container">
    <div class="row pt-4 pb-3">
        <div class="col-6">
            <h2 class="text-primary">
                Slider Yönetimi
            </h2>
        </div>
        <div class="col-6 text-end">
            <a asp-controller="Slider" asp-action="Upsert" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Yeni Slider Ekle
            </a>
        </div>
    </div>

    <div class="table-container">
        <table id="tblData" class="">
            <thead>
                <!-- DataTable will populate headers -->
            </thead>
            <tbody>
                <!-- DataTable will populate data -->
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <partial name="_PartialReqScript" />

    <script>
        $(document).ready(() => {
            initializeDataTableWithOption('Slider', [
                {
                    title: 'Resim',
                    data: 'imageUrl',
                    width: '15%',
                    render: function (data) {
                        if (data) {
                            return `<img src="${data}" alt="Slider Görseli" style="width: 100px; height: 60px; object-fit: cover;" />`;
                        }
                        return 'Resim Yok';
                    }
                },
                {
                    title: 'Başlık',
                    data: 'title',
                    width: '20%'
                },

                {
                    title: 'Sıralama',
                    data: 'displayOrder',
                    width: '10%'
                },
                {
                    title: 'Durum',
                    data: 'isActive',
                    width: '10%',
                    render: function (data) {
                        return data ?
                            '<span class="badge bg-success">Aktif</span>' :
                            '<span class="badge bg-danger">Pasif</span>';
                    }
                },
                {
                    title: 'Oluşturulma Tarihi',
                    data: 'createdDate',
                    width: '15%',
                    render: function(data) {
                        return new Intl.DateTimeFormat('tr-TR', {
                            day: '2-digit',
                            month: '2-digit',
                            year: 'numeric',
                            hour: '2-digit',
                            minute: '2-digit',
                            hour12: false
                        }).format(new Date(data)).replace(',', ' -');
                    }
                }
            ]);
        });
    </script>
}
