@model List<Blog>
@section Styles {
	<link href="~/lib/datatables.net-dt/css/datatables.datatables.min.css" rel="stylesheet" />
	<link href="~/admin/styles/table.css" rel="stylesheet" />
}

<div class="container">
    <div class="row pt-4 pb-3">
        <div class="col-6">
            <h2 class="text-primary">
                Blog Yazıları
            </h2>
        </div>
        <div class="col-6 text-end">
            <a asp-controller="Blog" asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Yeni Blog Yazısı Oluştur
            </a>
        </div>
    </div>

    <div class="table-container">
        <table id="tblData" class="">
            <thead>
                <!-- DataTable will populate headers -->
            </thead>
            <tbody>
                <!-- DataTable will populate data -->
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <partial name="_PartialReqScript" />

    <script>
        $(document).ready(() => {
            initializeDataTableWithOption('Blog', [
                {
                    title: 'Başlık',
                    data: 'title',
                    width: '20%'
                },
                {
                    title: 'Dil',
                    data: 'Language',
                    width: '10%',
                    render: function(data) {
                        return data === 'tr' ? 
                            '<span class="badge bg-primary">TR</span>' : 
                            '<span class="badge bg-info text-dark">EN</span>';
                    }
                },
                {
                    title: 'İçerik Türü',
                    data: 'contentType.name',
                    width: '15%',
                    render: function (data) {
                        return data || 'Yok';
                    }
                },
                {
                    title: 'Slug',
                    data: 'slug',
                    width: '15%'
                },
                {
                    title: 'Durum',
                    data: 'isPublished',
                    width: '10%',
                    render: function (data) {
                        return data ?
                            '<span class="badge bg-success">Yayınlandı</span>' :
                            '<span class="badge bg-warning text-dark">Taslak</span>';
                    }
                },
                {
                    title: 'Oluşturuldu',
                    data: 'createdAt',
                    width: '15%',
                    render: function(data) {
                        return new Intl.DateTimeFormat('tr-TR', {
                            day: '2-digit',
                            month: '2-digit',
                            year: 'numeric',
                            hour: '2-digit',
                            minute: '2-digit',
                            hour12: false
                        }).format(new Date(data)).replace(',', ' -');
                    }
                }
            ]);
        });
    </script>
} 