
@section Styles{
    <link rel="stylesheet" href="~/css/on-kayit-formu.css">
    <link rel="stylesheet" href="~/css/online-bilet.css">
        <style>
            .banner {
                position: relative;
                background-image: url('./images/LES\ 2.jpg');
                /* Görselin yolu */
                background-size: cover;
                background-position: center;
                height: 300px;
                /* Yüksekliği isteğe göre ayarlayın */
                color: white;
                font-family: Arial, sans-serif;
            align-items: center;
            text-align: center;
        }

        .banner-yazi {
            position: relative;
            font-size: 48px;
            font-weight: bold;
            padding-top: 180px;

        }
    </style>
}
@{
    ViewData["Title"] = "LESEXPO";
    ViewData["Description"] = "LESEXPO";
    ViewData["Keywords"] = "LESEXPO";
    ViewData["Author"] = "LESEXPO";

}

    <div class="banner">
        <div class="banner-yazi">LES-EXPO</div>
        <div class="breadcrumb-1 mt-1">
            <a href="index.html">Ana Sayfa</a> /
            <a href="on-kayit-formu.html">Ön Kayıt Formu</a>
        </div>
    </div>

        <div class="container my-5">
            <div class="form-container">
                <form>
                    <!-- First Row -->
                    <div class="row mb-4">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="sirketAdmini">Şirket Adınız *</label>
                                <input type="text" class="form-control" id="sirketAdmini" required>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="adinaSoyadina">Adınız Soyadınız *</label>
                                <input type="text" class="form-control" id="adinaSoyadina" required>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="gorevTitle">Göreviniz *</label>
                                <input type="text" class="form-control" id="gorevTitle" required>
                            </div>
                        </div>
                    </div>

                    <!-- Second Row -->
                    <div class="row mb-4">
                        <div class="col-12">
                            <div class="form-group">
                                <label for="sirketAdresi">Şirket Adresiniz *</label>
                                <textarea class="form-control" id="sirketAdresi" rows="3" required></textarea>
                            </div>
                        </div>
                    </div>

                    <!-- Third Row -->
                    <div class="row mb-4">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="ulke">Ülke *</label>
                                <select class="form-select" id="ulke" required>
                                    <option value="">Lütfen Seçiniz</option>
                                    <option value="turkiye">Türkiye</option>
                                    <option value="almanya">Almanya</option>
                                    <option value="fransa">Fransa</option>
                                    <option value="ingiltere">İngiltere</option>
                                    <option value="rusya">Rusya</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="sehir">Şehir *</label>
                                <select class="form-select" id="sehir" required>
                                    <option value="">Lütfen Önce Ülke Seçiniz</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="telefon">Telefon *</label>
                                <div class="input-group">
                                    <span class="input-group-text" id="phoneCode">
                                        <img src="https://upload.wikimedia.org/wikipedia/commons/b/b4/Flag_of_Turkey.svg"
                                            alt="TR" width="20" id="countryFlag">
                                        +90
                                    </span>
                                    <input type="tel" class="form-control" id="telefon" placeholder="501 234 56 78"
                                        required>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Fourth Row -->
                    <div class="row mb-4">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="epostaAdresi">E-Posta Adresiniz *</label>
                                <input type="email" class="form-control" id="epostaAdresi" required>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="webSitesi">Web Sitesi Adresiniz/Giriniz</label>
                                <input type="url" class="form-control" id="webSitesi">
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="faaliyetAlaniniziGiriniz">Faaliyet Alanınızı Giriniz *</label>
                                <input type="text" class="form-control" id="faaliyetAlaniniziGiriniz" required>
                            </div>
                        </div>
                    </div>

                    <!-- Fifth Row -->
                    <div class="row mb-4">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="urunGrubuGiriniz">Ürün Grubunuzu Giriniz *</label>
                                <input type="text" class="form-control" id="urunGrubuGiriniz" required>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="markalarinizGiriniz">Markalarınızı Giriniz *</label>
                                <input type="text" class="form-control" id="markalarinizGiriniz" required>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="ayrintiliMerkezi">Ayırtmak İstediğiniz Metrekareyi Giriniz *</label>
                                <input type="text" class="form-control" id="ayrintiliMerkezi" required>
                            </div>
                        </div>
                    </div>

                    <!-- Sixth Row -->
                    <div class="row mb-4">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="kurulusTarihi">Firmanızın Kuruluş Tarihi *</label>
                                <input type="date" class="form-control" id="kurulusTarihi" placeholder="GG-AA-YYYY"
                                    required>
                            </div>
                        </div>
                    </div>

                    <!-- Seventh Row -->
                    <div class="row mb-4">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="aktiviteTuru">Firmanızın Aktivite Türü *</label>
                                <select class="form-select" id="aktiviteTuru" required>
                                    <option selected>Seçiniz</option>
                                    <option value="uretici">Üretici</option>
                                    <option value="ithalatci">İthalatçı</option>
                                    <option value="ihracatci">İhracatçı</option>
                                    <option value="distribütor">Distribütör</option>
                                    <option value="toptanci">Toptancı</option>
                                    <option value="perakendeci">Perakendeci</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="ihracatCirosu">Firmanızın İhracat Cirosu *</label>
                                <div class="input-group">
                                    <span class="input-group-text">USD</span>
                                    <input type="text" class="form-control" id="ihracatCirosu" required>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="toplamCirosu">Firmanızın Toplam Cirosu *</label>
                                <div class="input-group">
                                    <span class="input-group-text">USD</span>
                                    <input type="text" class="form-control" id="toplamCirosu" required>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Eighth Row -->
                    <div class="row mb-4">
                        <div class="col-12">
                            <div class="form-group">
                                <label for="personelSayisi">Firmanızda İstihdam Edilen Personel Sayısı *</label>
                                <input type="number" class="form-control" id="personelSayisi" required>
                            </div>
                        </div>
                    </div>

                    <!-- National Fairs Section -->
                    <div class="section-title mb-3">Firmanızın Ulusal Fuarlara Katılımı</div>
                    <div id="nationalFairsContainer">
                        <div class="form-row-container">
                            <div class="row mb-4 national-fair-row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="ulusalFuarAdi">Fuar Adı</label>
                                        <input type="text" class="form-control" id="ulusalFuarAdi">
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="ulusalKatilimYili">Katılım Yılı</label>
                                        <input type="text" class="form-control" id="ulusalKatilimYili">
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row mb-4">
                        <div class="col-12 text-end">
                            <button type="button" class="btn btn-dark" id="addNationalFair">Yeni Ekle</button>
                        </div>
                    </div>

                    <!-- International Fairs Section -->
                    <div class="section-title mb-3">Firmanızın Uluslararası Fuarlara Katılımı</div>
                    <div id="internationalFairsContainer">
                        <div class="form-row-container">
                            <div class="row mb-4 international-fair-row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="uluslararasiFuarAdi">Fuar Adı</label>
                                        <input type="text" class="form-control" id="uluslararasiFuarAdi">
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="uluslararasiKatilimYili">Katılım Yılı</label>
                                        <input type="text" class="form-control" id="uluslararasiKatilimYili">
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row mb-4">
                        <div class="col-12 text-end">
                            <button type="button" class="btn btn-dark" id="addInternationalFair">Yeni Ekle</button>
                        </div>
                    </div>
                    <!-- Terms and Captcha -->
                    <div class="form-section-ob">
                        <div class="form-group-ob checkbox-group-ob">
                            <input type="checkbox" id="terms" name="terms" required>
                            <label for="terms">Aydınlatma Metni ve Kişisel Verilerin Kullanılması ve Korunması ile
                                ilgili bilgilendirme yazısını okudum, kabul ediyorum. <span
                                    class="required-ob">*</span></label>
                        </div>
                    </div>

                    <div class="row mb-4">

                        <div class="col-md-6">
                            <div class="input-group">

                                <button class="btn btn-primary" type="submit">Hemen Yerinizi Ayırtın</button>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>



@section Scripts{
        <!-- Custom Scripts -->
        <script src="~/js/on-kayit-formu.js"></script>

    }

