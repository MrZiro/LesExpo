@{
    ViewData["Title"] = "Ziyaretçi Profili";
    ViewData["Description"] = "Ziyaretçi Profili";
    ViewData["Keywords"] = "Ziyaretçi Profili";
    ViewData["CanonicalUrl"] = "https://lesexpo.com/tr/ziyaretci-profili";
    ViewData["AlternateUrls"] = new string[] { "https://lesexpo.com/en/visitor-profile" };
}
@section Styles {
  <link rel="stylesheet" href="~/css/hakkimizda.css">
    <style>
    .banner {
      position: relative;
      background-image: url('/images/LES4.jpg');
      /* Görselin yolu */
      background-size: cover;
      background-position: center;
      height: 300px;
      /* Yüksekliği isteğe göre ayarlayın */
      color: white;
      font-family: Arial, sans-serif;
      align-items: center;
      text-align: center;
    }

    .banner-yazi {
      position: relative;
      font-size: 48px;
      font-weight: bold;
      padding-top: 178px;
    }
    .pharmaist-section{text-align: center;}

  </style>
}




  <div class="banner">
    <div class="banner-yazi">LES-EXPO</div>
    <div class="breadcrumb-1">
      <a href="/tr">Ana Sayfa /</a>
      <a href="/tr/ziyaretci-profili">Ziyaretçi Profili</a>
    </div>
  </div>

<div class="container main-container">
    <div class="row">
        <!-- Sidebar -->
        <partial name="Components/AboutUs/_Sidebar" />
        <!-- Main content -->
        <div class="container-nze content-area">
            <section>
                <h1 class="h1-ziyaretci mb-3 text-dark">LES-EXPO<br>NEDEN ZİYARET ETMELİSİNİZ ?</h1>
                <div class="card-grid-nze">
                    <!-- Kart 1 -->
                    <div class="card-nze">
                        <div class="icon-nze">
                            <i class="fas fa-lightbulb"></i>
                        </div>
                        <p class="card-text-nze">Sektördeki Yenilikleri Keşfedin.</p>
                    </div>

                    <!-- Kart 2 -->
                    <div class="card-nze">
                        <div class="icon-nze">
                            <i class="far fa-handshake"></i>
                        </div>
                        <p class="card-text-nze">Lider Firmalarla Tanışın.</p>
                    </div>

                    <div class="card-nze">
                        <div class="icon-nze">
                            <i class="fa-solid fa-award"></i>
                        </div>
                        <p class="card-text-nze">Eğitim ve Seminer Fırsatları.</p>
                    </div>

                    <div class="card-nze">
                        <div class="icon-nze">
                            <i class="fa-solid fa-network-wired"></i>
                        </div>
                        <p class="card-text-nze">Ağ Kurma İmkanları.</p>
                    </div>

                    <div class="card-nze">
                        <div class="icon-nze">
                            <i class="fa-solid fa-globe"></i>
                        </div>
                        <p class="card-text-nze">Geleceğe Yön Verecek Teknolojiler.</p>
                    </div>

                    <!-- Kart 3 -->
                    <div class="card-nze">
                        <div class="icon-nze">
                            <i class="fas fa-cubes"></i>
                        </div>
                        <p class="card-text-nze">Sektörel Çözümleri Bir Arada Görün.</p>
                    </div>

                    <!-- Kart 4 -->
                    <div class="card-nze">
                        <div class="icon-nze">
                            <i class="fas fa-leaf"></i>
                        </div>
                        <p class="card-text-nze">Sürdürülebilirlik Çözümleri Keşfedin</p>
                    </div>

                    <!-- Kart 5 -->
                    <div class="card-nze">
                        <div class="icon-nze">
                            <i class="fas fa-chart-line"></i>
                        </div>
                        <p class="card-text-nze">Rekabetçi Avantaj Kazanın</p>
                    </div>

                    <!-- Kart 6 -->
                    <div class="card-nze">
                        <div class="icon-nze">
                            <i class="fas fa-industry"></i>
                        </div>
                        <p class="card-text-nze">Endüstriyel Altyapı İhtiyacınızı Karşılayın </p>
                    </div>
                </div>
            </section>
        </div>
    </div>
</div>
<!-- Sidebar mobile toggle button -->
<button class="sidebar-toggle-button d-md-none">
    <i class="fas fa-bars"></i>
</button>
<!-- Sidebar mobile toggle button -->
<button class="sidebar-toggle-button d-md-none">
    <i class="fas fa-bars"></i>
</button>


@section Scripts {
  <script src="~/js/hakkimizda.js"></script>

}