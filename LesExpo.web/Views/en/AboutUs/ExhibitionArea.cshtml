@{
    ViewData["Title"] = "Exhibition Area";
    ViewData["Description"] = "Istanbul Expo Center - Turkey's largest fairground. Total fair area of 200,000 m2, parking capacity for 7500 vehicles.";
    ViewData["Keywords"] = "Istanbul Expo Center, exhibition area, fairground, LES-EXPO, exhibition center features";
}
@section Styles {
  <link rel="stylesheet" href="~/css/hakkimizda.css">
  <link rel="stylesheet" href="~/css/sidebar.css">
    <style>
    .banner {
      position: relative;
      background-image: url('/images/LES5.jpg');
      /* Görselin yolu */
      background-size: cover;
      background-position: center;
      height: 300px;
      /* Yüksekliği isteğe göre ayarlayın */
      font-family: Arial, sans-serif;
      align-items: center;
      text-align: center;
    }

    .banner-yazi {
      position: relative;
      font-size: 48px;
      font-weight: bold;
      padding-top: 178px;
      color: white;
    }

    .breadcrumb-1 a {
      color: white;
    }

    .img-harita {
      width: 45%;
    }
    .pharmaist-section{text-align: center;}

    @@media(max-width: 500px) {
      .img-harita {

        width: 100%;
      }
    }
  </style>
}




  <div class="banner">
    <div class="banner-yazi">LES-EXPO</div>
    <div class="breadcrumb-1">
      <a href="/en">Home Page /</a>
      <a href="/en/exhibition-area">Exhibition-Area</a>
    </div>
  </div>

        <div class="container main-container">
            <div class="row">
                <!-- Sidebar -->
                <partial name="Components/AboutUs/_SidebarHakkimizda" />
                <!-- Main content -->
                <div class="content-area">
                    <section class="pharmaist-section">
                        <div class="pharmaist-text">
                            <h2>Turkey's Largest Fairground</h2>
                            <p>Total fair area 200,000 m2</p>
                            <p>The largest international exhibition center in Eurasia</p>
                            <p>Electronic parking system for 7500 vehicles (1 indoor and 2 outdoor giant parking lots)
                            </p>
                            <h4>STRONG INFRASTRUCTURE AND SUPERIOR SERVICE</h4>
                            <p>It provides an infrastructure that will fully meet the energy, heating-cooling, air
                                conditioning, telecommunication, water, air, compressed air requirements that will
                                support all kinds of technological tools and systems. It responds to all needs
                                immediately.</p>
                            <p>Its proximity to the ring roads, the metro passing through the center, the availability
                                of very large parking areas,
                                environmental arrangements and excellent infrastructure have made İFM one of the
                                attractive centers. It is located in the same
                                complex
                                together with İDTM Business Blocks, WOW Hotels, WOW Congress Center.
                            </p>
                            <h4>PARKING AREA</h4>
                            <p>The 7500-vehicle capacity car park, arranged according to the hall locations, provides
                                participants and visitors with comfortable accommodation and security throughout the
                                fair.</p>
                        </div>
                </div>
                </section>
            </div>
        </div>
        <!-- Sidebar mobile toggle button -->
        <button class="sidebar-toggle-button d-md-none">
            <i class="fas fa-bars"></i>
        </button>

        <section class="text-center">
            <img src="/images/harita-gorsel.jpeg" class="img-harita" alt="">
        </section>


@section Scripts {
      <script src="~/js/hakkimizda.js"></script>

}