@{
    ViewData["Title"] = "Media Logo";
    ViewData["Description"] = "Media Logo";
    ViewData["Keywords"] = "Media Logo";

}
@section Styles{
    <link rel="stylesheet" href="/css/medya-logo.css">

    <style>
        .banner {
            position: relative;
            background-image: url('/images/LES4.jpg');
            /* Görselin yolu */
            background-size: cover;
            background-position: center;
            height: 300px;
            /* Yüksekliği isteğe göre ayarlayın */
            color: white;
            font-family: Arial, sans-serif;
            align-items: center;
            text-align: center;
        }

        .banner-yazi {
            position: relative;
            font-size: 48px;
            font-weight: bold;
            padding-top: 178px;
        }
    </style>
    }

    <div class="banner">
        <div class="banner-yazi">LES-EXPO</div>
        <div class="breadcrumb-1">
            <a href="/en">Home Page</a> /
            <a href="/en/media-logo">Media</a>
        </div>
    </div>

        <div class="logo-container-2" id="logoContainer">
            <!-- Logolar buraya JavaScript ile eklenecek -->
        </div>



        <!-- Custom Scripts -->
@section Scripts {
    <script src="/js/medya-logo.js"></script>
}