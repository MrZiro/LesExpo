@{
    ViewData["Title"] = "LES Insights";
    ViewData["Description"] = "LES Insights";
    ViewData["Keywords"] = "LES Insights";

}
@section styles{
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/insights.css">
    <link rel="stylesheet" href="/css/sidebar.css">
    <style>
        .banner {
            position: relative;
            background-image: url('/images/LES5.jpg');
            /* Görselin yolu */
            background-size: cover;
            background-position: center;
            height: 300px;
            /* Yüksekliği isteğe göre ayarlayın */
            font-family: Arial, sans-serif;
            align-items: center;
            text-align: center;
        }

        .banner::before {
            content: '';
            background-color: rgba(0, 0, 0, 0.1);
            /* parlaklık azaltıcı katman */
            z-index: 1;
        }

        .banner-yazi {
            position: relative;
            font-size: 48px;
            font-weight: bold;
            padding-top: 178px;
            color: white;
        }

        .breadcrumb-1 a {
            color: white;
        }
    </style>
}
    
    <div class="banner">
        <div class="banner-yazi">LES-EXPO</div>
        <div class="breadcrumb-1">
            <a href="/en">Home Page /</a>
            <a href="/en/les-insights">LES Insights</a>
        </div>
    </div>  

        <div class="container main-container">
            <div class="row">
                <!-- Sidebar -->
                <div class="col-md-3 sidebar-container">
                    <div class="sidebar">
                        <div class="sidebar-sticky">
                            <div class="sidebar-header p-3 mb-3 text-center">
                                <h3 class="" data-translate="hakkimizda.sidebar.mainTitle">LESEXPO</h3>
                                <p class="small mb-0" data-translate="hakkimizda.sidebar.subTitle">LES Insights
                                </p>
                            </div>
                            <ul class="nav flex-column">
                                <!-- Hakkımızda -->
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="collapse"
                                        data-bs-target="#hakkimizdaSubmenu" aria-expanded="true">
                                        <span class="menu-icon"><i class="fas fa-info-circle"></i></span>
                                        <span data-translate="hakkimizda.sidebar.aboutUs">LES Insights</span>
                                    </a>
                                    <div class="collapse show" id="hakkimizdaSubmenu">
                                        <ul class="nav flex-column submenu">
                                            <li class="nav-item">
                                                <a class="nav-link" href="/en/b2b-meetings">
                                                    <i class="fas fa-angle-right me-2"></i>
                                                    <span data-translate="hakkimizda.sidebar.bfmAbout">B2B
                                                        Meetings</span>
                                                </a>
                                            </li>
                                            <li class="nav-item">
                                                <a class="nav-link active" href="/en/les-insights">
                                                    <i class="fas fa-angle-right me-2"></i>
                                                    <span data-translate="hakkimizda.sidebar.presidentMessage">LES
                                                        Insights</span>
                                                </a>
                                            </li>
                                            <li class="nav-item">
                                                <a class="nav-link" href="/en/les-experiences">
                                                    <i class="fas fa-angle-right me-2"></i>
                                                    <span data-translate="hakkimizda.sidebar.qualityPolicy">LES
                                                        Experiences</span>
                                                </a>
                                            </li>
                                        </ul>
                                    </div>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
                <!-- Main content -->
                <div class="content-area">
                    <section class="pharmaist-section">
                        <div class="pharmaist-text">
                            <h2 class="fw-bold fs-1">LES Insights:</h2>
                            <h4>LES-EXPO 2025 Istanbul: The Gathering of Those Who Design, Lift, Carry, and Drive the
                                World's Load! </h4>
                            <p class="light p-0">Shaping the future of load engineering at LES Insights!</p>
                            <p>
                                <strong>LES Insights</strong> is a professional platform dedicated to presenting load
                                engineering as an
                                independent and multidisciplinary discipline. Through Dialogues and Spotlights sessions,
                                we share the industry's best practices, innovative technologies, and
                                sustainability-focused success stories.
                            </p>
                            <ul>
                                <li> <strong>Dialogues:</strong> Interactive discussions bringing together industry
                                    stakeholders.</li>
                                <li><strong>Spotlights:</strong> Inspiring projects and expertise stories.</li>
                            </ul>
                            <p>
                                From young engineers to industry leaders, LES Insights offers knowledge, connections,
                                and inspiration for all. With its soon-to-be-announced program, LES Insights will shape
                                the future of load engineering. Stay tuned for the latest program at <a href="#"
                                    class="link">Link</a>
                            </p>
                        </div>
                    </section>
                </div>
            </div>
        </div>
        <!-- Sidebar mobile toggle button -->
        <button class="sidebar-toggle-button d-md-none">
            <i class="fas fa-bars"></i>
        </button>


@section Scripts {
    <script src="/js/hakkimizda.js"></script>
    <script src="/js/main.js"></script>
}


