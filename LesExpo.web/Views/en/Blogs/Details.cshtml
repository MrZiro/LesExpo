@using System.Globalization
  @model Blog

@{
    ViewData["Title"] = Model.Title;
    ViewData["Description"] = Model.MetaDescription;
    ViewData["Keywords"] = Model.MetaKeywords;

    var lang = ViewData["Lang"].ToString();
    var culture = lang == "en" ? new CultureInfo("en-US") : new CultureInfo("tr-TR");
}
  @section Styles{
    <link rel="stylesheet" href="~/css/blog-single-page.css">
    
    <style>
        .banner {
            position: relative;
            background-image: url('@Url.Content("~/images/LES5.jpg")');
            /* Görselin yolu */
            background-size: cover;
            background-position: center;
            height: 300px;
            /* Yüksekliği isteğe göre ayarlayın */
            font-family: Arial, sans-serif;
            align-items: center;
            text-align: center;
            }

            .banner-yazi {
            position: relative;
            font-size: 48px;
            font-weight: bold;
            padding-top: 178px;
            color: white;
            }

            .breadcrumb-1 a {
            color: white;
            }
    </style>
  }
  
<div class="banner">
    <div class="banner-yazi">LES-EXPO</div>
    <div class="breadcrumb-1">
    </div>
</div>

<div class="container py-5">
    <div class="breadcrumb justify-content-center mt-5">
        <a asp-controller="Home" asp-action="Index" asp-route-lang="@lang">Home Page</a> /
        <a asp-controller="Blogs" asp-action="Index" asp-route-lang="@lang">All News</a> /
        <a asp-controller="Blogs" asp-action="Details" asp-route-lang="@lang" asp-route-slug="@Model.Slug">@Model.Title</a>
    </div>
    <div class="row justify-content-center">
        <div class="col-12">
            <div class="news-container">

                <div class="news-content">
                    <!-- Görsel Eklendi -->
                    <h2 class="blog-first-title">@Model.Title</h2>
                    @Html.Raw(Model.Content)
                </div>
                <div class="mt-4">
                    <small class="text-muted">
                        <i class="far fa-calendar-alt"></i> @Model.CreatedAt.ToString("dd MMMM yyyy", culture)
                    </small>
                    <small class="text-muted ml-2">
                        <i class="fas fa-tag"></i> @Model.ContentType.Name
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>
    <!-- Haberler Card Section -->

<div class="container-haberler">
    <div class="header-haberler">
        <h2><i class="fas fa-arrow-right"></i>OTHER NEWS</h2>
        <div class="header-right">
            <a href="/en/all-news" class="all-news">ALL NEWS</a>
        </div>
    </div>

    <div class="slider-container-haberler">
        <div class="slider-haberler" id="slider-haberler">
            <!-- Related blog-single-page will breadcrumb loaded via js-->
            

        </div>
    </div>
</div>



@section Scripts{
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
    
   <!-- Custom Scripts -->
    <script src="~/js/main.js"></script>

    <script>

        $(document).ready(function(){
            fetchData();
        });
        
        function getLangFromUrl() {
        const path = window.location.pathname; // Gets the path part of the URL, e.g., "/en/home/index"
        const segments = path.split('/');      // Splits the path into an array: ["", "en", "home", "index"]

        // The 'lang' segment will be at index 1 if the URL structure is consistent
        if (segments.length > 1) {
            return segments[1];
        }

        return null; // Or a default language if 'lang' is not found
        }
        var lang = getLangFromUrl();

        function fetchData(){
            $.ajax({
                url: `/${lang}/Blogs/GetAllBlogs`,
                type: "GET",
                success: function(response){
                    console.log(response);
                    var relatedBlogs = response.filter(blog => blog.slug !== '@Model.Slug');
                    var sliderContainer = $('#slider-haberler');
                    sliderContainer.empty();

                    console.log(relatedBlogs);
                    relatedBlogs.forEach(blog => {
                        var blogHtml = `
                            <div class="card-haberler">
                                <div class="card-image-haberler">
                                    <img src="${blog.image}" alt="${blog.title}">
                                    <div class="card-date-haberler">
                                        <i class="far fa-calendar-alt"></i> ${blog.date}
                                    </div>
                                </div>
                                <div class="card-content-haberler">
                                    <h3 class="card-title-haberler">${blog.title}</h3>
                                    <a href="/${lang}/blog-detail/${blog.slug}" class="read-more-haberler">Read More <i class="fas fa-arrow-right"></i></a>
                                </div>
                            </div>
                        `;
                        sliderContainer.append(blogHtml);
                    });
                },
                error: function(error){
                    console.error("Error from fetchData:", error);
                }
            });
        }
    </script>

}