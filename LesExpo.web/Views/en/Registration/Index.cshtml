@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    ViewData["Title"] = "Kayıt - LES-EXPO";
    ViewData["Description"] = "LES-EXPO Registration Page";
    ViewData["Keywords"] = "LES-EXPO, Registration, Fair";
    ViewData["Author"] = "LESEXPO";
}

<div class="container my-5">
    <div class="row">
        <div class="col-12">
            <h1 class="text-center mb-4">LES-EXPO Kayıt</h1>
            <div class="card">
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <div class="card h-100">
                                <div class="card-body d-flex flex-column">
                                    <h3>Ön Kayıt Formu</h3>
                                    <p>Fuarımıza katılımcı olarak yer almak için ön kayıt formunu doldurabilirsiniz.</p>
                                    <p>Ön kayıt formunu doldurduktan sonra ekibimiz sizinle iletişime geçecektir.</p>
                                    <div class="mt-auto">
                                        <a asp-controller="Registration" asp-action="OnKayitFormu" class="btn btn-primary">Ön Kayıt Formu</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 mb-4">
                            <div class="card h-100">
                                <div class="card-body d-flex flex-column">
                                    <h3>İletişim</h3>
                                    <p>Herhangi bir sorunuz varsa bizimle iletişime geçebilirsiniz.</p>
                                    <p>Telefon: +90 (224) 294 85 50</p>
                                    <p>E-posta: info@les-expo.com</p>
                                    <div class="mt-auto">
                                        <a asp-controller="Contact" asp-action="Iletisim" class="btn btn-primary">İletişim Formu</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
