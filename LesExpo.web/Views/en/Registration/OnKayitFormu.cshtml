@model LesExpo.Models.ViewModels.RegistrationVM
@{
    ViewData["Title"] = "Pre-Registration Form";
    ViewData["Description"] = "LES-EXPO Pre-Registration Form";
    ViewData["Keywords"] = "LES-EXPO, Pre-Registration, Fair";
}

@section Styles{
    <link rel="stylesheet" href="~/css/on-kayit-formu.css">
    <link rel="stylesheet" href="~/css/online-bilet.css">
        <style>
            .banner {
                position: relative;
                background-image: url('/images/LES2.jpg');
                /* Görselin yolu */
                background-size: cover;
                background-position: center;
                height: 300px;
                /* Yüksekliği isteğe göre ayarlayın */
                color: white;
                font-family: Arial, sans-serif;
            align-items: center;
            text-align: center;
        }

        .banner-yazi {
            position: relative;
            font-size: 48px;
            font-weight: bold;
            padding-top: 180px;
        }
        
        .alert {
            padding: 15px;
            margin-bottom: 20px;
            border: 1px solid transparent;
            border-radius: 4px;
        }

        .alert-success {
            color: #3c763d;
            background-color: #dff0d8;
            border-color: #d6e9c6;
        }

        .alert-danger {
            color: #a94442;
            background-color: #f2dede;
            border-color: #ebccd1;
        }

        .text-danger {
            color: #dc3545;
            font-size: 0.875rem;
            margin-top: 5px;
            display: block;
        }
    </style>
}
@{
    ViewData["Title"] = "Ön Kayıt Formu - LESEXPO";
    ViewData["Description"] = "LESEXPO Ön Kayıt Formu";
    ViewData["Keywords"] = "LESEXPO, Ön Kayıt, Fuar";
    ViewData["Author"] = "LESEXPO";
}

    <div class="banner">
        <div class="banner-yazi">LES-EXPO</div>
        <div class="breadcrumb-1 mt-1">
            <a asp-controller="Home" asp-action="Index">Home Page</a> /
            <a href="/en/pre-registration-form">Pre-Registration Form</a>
        </div>
    </div>

        <div class="container my-5">
            <div class="form-container">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success" role="alert">
                        @TempData["Success"]
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger" role="alert">
                        @TempData["Error"]
                    </div>
                }
                <form method="post">
                    @Html.AntiForgeryToken()
                    <!-- First Row -->
                    <div class="row mb-4">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="SirketAdi">Company Name *</label>
                                <input asp-for="SirketAdi" class="form-control" required>
                                <span asp-validation-for="SirketAdi" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="AdSoyad">Name and Surname *</label>
                                <input asp-for="AdSoyad" class="form-control" required>
                                <span asp-validation-for="AdSoyad" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Gorev">Job Title *</label>
                                <input asp-for="Gorev" class="form-control" required>
                                <span asp-validation-for="Gorev" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <!-- Second Row -->
                    <div class="row mb-4">
                        <div class="col-12">
                            <div class="form-group">
                                <label asp-for="SirketAdresi">Address *</label>
                                <textarea asp-for="SirketAdresi" class="form-control" rows="3" required></textarea>
                                <span asp-validation-for="SirketAdresi" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <!-- Third Row -->
                    <div class="row mb-4">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Ulke">Country *</label>
                                <select asp-for="Ulke" class="form-select" id="ulke" required>
                                    <option value="">Please Select</option>
                                </select>
                                <span asp-validation-for="Ulke" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Sehir">City *</label>
                                <select asp-for="Sehir" class="form-select" id="sehir" required>
                                    <option value="">Please Select</option>
                                </select>
                                <span asp-validation-for="Sehir" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Telefon">Phone *</label>
                                <div class="input-group">
                                    <input asp-for="Telefon" type="tel" class="form-control" id="telefon" placeholder="+90 501 234 56 78" required>
                                </div>
                                <span asp-validation-for="Telefon" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <!-- Fourth Row -->
                    <div class="row mb-4">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Email">Email *</label>
                                <input asp-for="Email" type="email" class="form-control" required>
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="WebSitesi">Website</label>
                                <input asp-for="WebSitesi" type="url" class="form-control">
                                <span asp-validation-for="WebSitesi" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="FaaliyetAlani">Company Activity *</label>
                                <select asp-for="FaaliyetAlani" class="form-select" id="FaaliyetAlani" required>
                                    <option value="">Please Select</option>
                                </select>
                                <span asp-validation-for="FaaliyetAlani" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <!-- Fifth Row -->
                    <div class="row mb-4">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="UrunGrubu">Products *</label>
                                <input asp-for="UrunGrubu" type="text" class="form-control" required>
                                <span asp-validation-for="UrunGrubu" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Markalar">Please enter the brand name *</label>
                                <input asp-for="Markalar" type="text" class="form-control" required>
                                <span asp-validation-for="Markalar" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="IstenenMetrekare">Square meter prices that you have requestedz *</label>
                                <input asp-for="IstenenMetrekare" type="text" class="form-control" required>
                                <span asp-validation-for="IstenenMetrekare" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                    

                    <!-- Sixth Row -->
                    <div class="row mb-4">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>Would you like us to visit your company? *</label>
                                <div class="radio-group">
                                    <div class="form-check form-check-inline">
                                        <input asp-for="FirmaZiyareti" class="form-check-input" type="radio" id="ziyaretEvet"
                                            value="evet" required>
                                        <label class="form-check-label" for="ziyaretEvet">Yes</label>
                                    </div>
                                    <div class="form-check form-check-inline">
                                        <input asp-for="FirmaZiyareti" class="form-check-input" type="radio" id="ziyaretHayir"
                                            value="hayir">
                                        <label class="form-check-label" for="ziyaretHayir">No</label>
                                    </div>
                                </div>
                                <span asp-validation-for="FirmaZiyareti" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>Detailed information about fair participation *</label>
                                <div class="radio-group-form">
                                    <div class="form-check form-check-inline">
                                        <input asp-for="FuarKatilim" class="form-check-input" type="radio"
                                            id="katilimIstiyorum" value="istiyorum" required>
                                        <label class="form-check-label" for="katilimIstiyorum">Yes</label>
                                    </div>
                                    <div class="form-check form-check-inline">
                                        <input asp-for="FuarKatilim" class="form-check-input" type="radio"
                                            id="katilimIstemiyorum" value="istemiyorum">
                                        <label class="form-check-label" for="katilimIstemiyorum">No</label>
                                    </div>
                                </div>
                                <span asp-validation-for="FuarKatilim" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="KurulusTarihi">Company Establishment Date *</label>
                                <input asp-for="KurulusTarihi" type="date" class="form-control" placeholder="GG-AA-YYYY" required>
                                <span asp-validation-for="KurulusTarihi" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <!-- Seventh Row -->
                    <div class="row mb-4">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="AktiviteTuru">Company Activity *</label>
                                <select asp-for="AktiviteTuru" class="form-select" required>
                                    <option value="">Please Select</option>
                                    <option value="uretici">Exporter</option>
                                    <option value="ithalatci">Producer</option>
                                    <option value="ihracatci">Importer</option>
                                    <option value="distribütor">Distributor</option>
                                    <option value="toptanci">Retailer</option>
                                    <option value="perakendeci">Wholesaler</option>
                                </select>
                                <span asp-validation-for="AktiviteTuru" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="IhracatCirosu">Company Export Turnover *</label>
                                <div class="input-group">
                                    <span class="input-group-text">USD</span>
                                    <input asp-for="IhracatCirosu" type="text" class="form-control" required>
                                </div>
                                <span asp-validation-for="IhracatCirosu" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="ToplamCiro">Total Turnover *</label>
                                <div class="input-group">
                                    <span class="input-group-text">USD</span>
                                    <input asp-for="ToplamCiro" type="text" class="form-control" required>
                                </div>
                                <span asp-validation-for="ToplamCiro" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <!-- Eighth Row -->
                    <div class="row mb-4">
                        <div class="col-12">
                            <div class="form-group">
                                <label asp-for="PersonelSayisi">Number of personnel employed in your company *</label>
                                <input asp-for="PersonelSayisi" type="number" class="form-control" required>
                                <span asp-validation-for="PersonelSayisi" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <!-- National Fairs Section -->
                    <div class="section-title mb-3">Participation of your company in national fairs</div>
                    <div id="nationalFairsContainer">
                        <div class="form-row-container">
                            <div class="row mb-4 national-fair-row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="ulusalFuarAdi">Fair Name</label>
                                        <input type="text" class="form-control ulusal-fuar-adi" id="ulusalFuarAdi">
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="ulusalKatilimYili">Year of Participation</label>
                                        <input type="text" class="form-control ulusal-katilim-yili" id="ulusalKatilimYili">
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row mb-4">
                        <div class="col-12 text-end">
                            <button type="button" class="btn btn-dark" id="addNationalFair">Add New</button>
                        </div>
                    </div>

                    <!-- International Fairs Section -->
                    <div class="section-title mb-3">Participation of your company in international fairs</div>
                    <div id="internationalFairsContainer">
                        <div class="form-row-container">
                            <div class="row mb-4 international-fair-row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="uluslararasiFuarAdi">Fair Name</label>
                                        <input type="text" class="form-control uluslararasi-fuar-adi" id="uluslararasiFuarAdi">
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="uluslararasiKatilimYili">Year of Participation</label>
                                        <input type="text" class="form-control uluslararasi-katilim-yili" id="uluslararasiKatilimYili">
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row mb-4">
                        <div class="col-12 text-end">
                            <button type="button" class="btn btn-dark" id="addInternationalFair">Add New</button>
                        </div>
                    </div>
                    <!-- Terms and Captcha -->
                    <div class="form-section-ob">
                        <div class="form-group-ob checkbox-group-ob">
                            <input type="checkbox" id="terms" name="terms" required>
                            <label for="terms">I have read and accepted the information and consent statement regarding the use and protection of personal data. <span
                                    class="required-ob">*</span></label>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6">
                            <div class="input-group">
                                <button class="btn btn-primary" type="submit">Book Your Place</button>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>

@section Scripts{
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/js/on-kayit-formu.js"></script>
    <script>
        // Form submission için ek JS
        document.addEventListener('DOMContentLoaded', function() {
            // Form submit olduğunda ulusal ve uluslararası fuarları topla
            document.querySelector('form').addEventListener('submit', function(e) {
                e.preventDefault();
                
                // Ulusal fuarları topla
                const ulusalFuarlar = [];
                document.querySelectorAll('.national-fair-row').forEach(function(row) {
                    const fuarAdi = row.querySelector('.ulusal-fuar-adi').value.trim();
                    const katilimYili = row.querySelector('.ulusal-katilim-yili').value.trim();
                    
                    if (fuarAdi && katilimYili) {
                        // Hidden input oluştur
                        const fuarAdiInput = document.createElement('input');
                        fuarAdiInput.type = 'hidden';
                        fuarAdiInput.name = 'UlusalFuarlar[' + ulusalFuarlar.length + '].FuarAdi';
                        fuarAdiInput.value = fuarAdi;
                        
                        const katilimYiliInput = document.createElement('input');
                        katilimYiliInput.type = 'hidden';
                        katilimYiliInput.name = 'UlusalFuarlar[' + ulusalFuarlar.length + '].KatilimYili';
                        katilimYiliInput.value = katilimYili;
                        
                        this.appendChild(fuarAdiInput);
                        this.appendChild(katilimYiliInput);
                        
                        ulusalFuarlar.push({ fuarAdi, katilimYili });
                    }
                }, this);
                
                // Uluslararası fuarları topla
                const uluslararasiFuarlar = [];
                document.querySelectorAll('.international-fair-row').forEach(function(row) {
                    const fuarAdi = row.querySelector('.uluslararasi-fuar-adi').value.trim();
                    const katilimYili = row.querySelector('.uluslararasi-katilim-yili').value.trim();
                    
                    if (fuarAdi && katilimYili) {
                        // Hidden input oluştur
                        const fuarAdiInput = document.createElement('input');
                        fuarAdiInput.type = 'hidden';
                        fuarAdiInput.name = 'UluslararasiFuarlar[' + uluslararasiFuarlar.length + '].FuarAdi';
                        fuarAdiInput.value = fuarAdi;
                        
                        const katilimYiliInput = document.createElement('input');
                        katilimYiliInput.type = 'hidden';
                        katilimYiliInput.name = 'UluslararasiFuarlar[' + uluslararasiFuarlar.length + '].KatilimYili';
                        katilimYiliInput.value = katilimYili;
                        
                        this.appendChild(fuarAdiInput);
                        this.appendChild(katilimYiliInput);
                        
                        uluslararasiFuarlar.push({ fuarAdi, katilimYili });
                    }
                }, this);
                
                // Formu gönder
                this.submit();
            });
        });
    </script>
}

