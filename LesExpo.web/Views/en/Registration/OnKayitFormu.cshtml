@model LesExpo.Models.ViewModels.RegistrationVM
@{
    ViewData["Title"] = "Pre-Registration Form";
    ViewData["Description"] = "LES-EXPO Pre-Registration Form";
    ViewData["Keywords"] = "LES-EXPO, Pre-Registration, Fair";
}

@section Styles{
    <link rel="stylesheet" href="~/css/on-kayit-formu.css">
    <link rel="stylesheet" href="~/css/online-bilet.css">
        <style>
            .banner {
                position: relative;
                background-image: url('/images/LES2.jpg');
                /* Görselin yolu */
                background-size: cover;
                background-position: center;
                height: 300px;
                /* Yüksekliği isteğe göre ayarlayın */
                color: white;
                font-family: Arial, sans-serif;
            align-items: center;
            text-align: center;
        }

        .banner-yazi {
            position: relative;
            font-size: 48px;
            font-weight: bold;
            padding-top: 180px;
        }
        
    </style>
}
@{
    ViewData["Title"] = "Ön Kayıt Formu - LESEXPO";
    ViewData["Description"] = "LESEXPO Ön Kayıt Formu";
    ViewData["Keywords"] = "LESEXPO, Ön Kayıt, Fuar";
    ViewData["Author"] = "LESEXPO";
}

    <div class="banner">
        <div class="banner-yazi">LES-EXPO</div>
        <div class="breadcrumb-1 mt-1">
            <a asp-controller="Home" asp-action="Index">Home Page</a> /
            <a href="/en/pre-registration-form">Pre-Registration Form</a>
        </div>
    </div>

        <div class="container my-5">
            <div class="form-container">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success" role="alert">
                        @TempData["Success"]
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger" role="alert">
                        @TempData["Error"]
                    </div>
                }
                <form method="post">
                    @Html.AntiForgeryToken()
                    <!-- First Row -->
                    <div class="row mb-4">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Registration.SirketAdi">Company Name *</label>
                                <input asp-for="Registration.SirketAdi" class="form-control" required>
                                <span asp-validation-for="Registration.SirketAdi" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Registration.AdSoyad">Name and Surname *</label>
                                <input asp-for="Registration.AdSoyad" class="form-control" required>
                                <span asp-validation-for="Registration.AdSoyad" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Registration.Gorev">Job Title *</label>
                                <input asp-for="Registration.Gorev" class="form-control" required>
                                <span asp-validation-for="Registration.Gorev" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <!-- Second Row -->
                    <div class="row mb-4">
                        <div class="col-12">
                            <div class="form-group">
                                <label asp-for="Registration.SirketAdresi">Address *</label>
                                <textarea asp-for="Registration.SirketAdresi" class="form-control" rows="3" required></textarea>
                                <span asp-validation-for="Registration.SirketAdresi" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <!-- Third Row -->
                    <div class="row mb-4">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Registration.Ulke">Country *</label>
                                <select asp-for="Registration.Ulke" class="form-select" id="ulke" required>
                                    <option value="">Please Select</option>
                                </select>
                                <span asp-validation-for="Registration.Ulke" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Registration.Sehir">City *</label>
                                <select asp-for="Registration.Sehir" class="form-select" id="sehir" required>
                                    <option value="">Please Select</option>
                                </select>
                                <span asp-validation-for="Registration.Sehir" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Registration.Telefon">Phone *</label>
                                <div class="input-group">
                                    <span class="input-group-text" id="phoneCode"><img id="countryFlag" src="https://upload.wikimedia.org/wikipedia/commons/b/b4/Flag_of_Turkey.svg" width="20" alt="TR" /> +90</span>
                                    <input asp-for="Registration.Telefon" type="tel" class="form-control" id="telefon" placeholder="05xx xxx xx xx" required>
                                </div>
                                <span asp-validation-for="Registration.Telefon" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <!-- Fourth Row -->
                    <div class="row mb-4">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Registration.Email">Email *</label>
                                <input asp-for="Registration.Email" type="email" class="form-control" required>
                                <span asp-validation-for="Registration.Email" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Registration.WebSitesi">Website</label>
                                <input asp-for="Registration.WebSitesi" type="text" class="form-control">
                                <span asp-validation-for="Registration.WebSitesi" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Registration.FaaliyetAlani">Company Activity *</label>
                                <select asp-for="Registration.FaaliyetAlani" class="form-select" id="FaaliyetAlani" required>
                                    <option value="">Please Select</option>
                                </select>
                                <span asp-validation-for="Registration.FaaliyetAlani" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <!-- Fifth Row -->
                    <div class="row mb-4">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Registration.UrunGrubu">Products *</label>
                                <input asp-for="Registration.UrunGrubu" type="text" class="form-control" required>
                                <span asp-validation-for="Registration.UrunGrubu" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Registration.Markalar">Please enter the brand name *</label>
                                <input asp-for="Registration.Markalar" type="text" class="form-control" required>
                                <span asp-validation-for="Registration.Markalar" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Registration.IstenenMetrekare">Square meter prices that you have requestedz *</label>
                                <input asp-for="Registration.IstenenMetrekare" type="text" class="form-control" required>
                                <span asp-validation-for="Registration.IstenenMetrekare" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                    

                    <!-- Sixth Row -->
                    <div class="row mb-4">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>Would you like us to visit your company? *</label>
                                <div class="radio-group">
                                    <div class="form-check form-check-inline">
                                        <input asp-for="Registration.FirmaZiyareti" class="form-check-input" type="radio" id="ziyaretEvet"
                                            value="evet" required>
                                        <label class="form-check-label" for="ziyaretEvet">Yes</label>
                                    </div>
                                    <div class="form-check form-check-inline">
                                        <input asp-for="Registration.FirmaZiyareti" class="form-check-input" type="radio" id="ziyaretHayir"
                                            value="hayir">
                                        <label class="form-check-label" for="ziyaretHayir">No</label>
                                    </div>
                                </div>
                                <span asp-validation-for="Registration.FirmaZiyareti" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>Detailed information about fair participation *</label>
                                <div class="radio-group-form">
                                    <div class="form-check form-check-inline">
                                        <input asp-for="Registration.FuarKatilim" class="form-check-input" type="radio"
                                            id="katilimIstiyorum" value="istiyorum" required>
                                        <label class="form-check-label" for="katilimIstiyorum">Yes</label>
                                    </div>
                                    <div class="form-check form-check-inline">
                                        <input asp-for="Registration.FuarKatilim" class="form-check-input" type="radio"
                                            id="katilimIstemiyorum" value="istemiyorum">
                                        <label class="form-check-label" for="katilimIstemiyorum">No</label>
                                    </div>
                                </div>
                                <span asp-validation-for="Registration.FuarKatilim" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Registration.KurulusTarihi">Company Establishment Date *</label>
                                <input asp-for="Registration.KurulusTarihi" type="date" class="form-control" placeholder="GG-AA-YYYY" required>
                                <span asp-validation-for="Registration.KurulusTarihi" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <!-- Seventh Row -->
                    <div class="row mb-4">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Registration.AktiviteTuru">Company Activity *</label>
                                <select asp-for="Registration.AktiviteTuru" class="form-select" required>
                                    <option value="">Please Select</option>
                                    <option value="uretici">Exporter</option>
                                    <option value="ithalatci">Producer</option>
                                    <option value="ihracatci">Importer</option>
                                    <option value="distribütor">Distributor</option>
                                    <option value="toptanci">Retailer</option>
                                    <option value="perakendeci">Wholesaler</option>
                                </select>
                                <span asp-validation-for="Registration.AktiviteTuru" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Registration.IhracatCirosu">Company Export Turnover *</label>
                                <div class="input-group">
                                    <span class="input-group-text">USD</span>
                                    <input asp-for="Registration.IhracatCirosu" type="text" class="form-control" required>
                                </div>
                                <span asp-validation-for="Registration.IhracatCirosu" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Registration.ToplamCiro">Total Turnover *</label>
                                <div class="input-group">
                                    <span class="input-group-text">USD</span>
                                    <input asp-for="Registration.ToplamCiro" type="text" class="form-control" required>
                                </div>
                                <span asp-validation-for="Registration.ToplamCiro" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <!-- Eighth Row -->
                    <div class="row mb-4">
                        <div class="col-12">
                            <div class="form-group">
                                <label asp-for="Registration.PersonelSayisi">Number of personnel employed in your company *</label>
                                <input asp-for="Registration.PersonelSayisi" type="number" class="form-control" required>
                                <span asp-validation-for="Registration.PersonelSayisi" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <!-- National Fairs Section -->
                    <div class="section-title mb-3">Participation of your company in national fairs</div>
                    <div id="nationalFairsContainer">
                        <div class="form-row-container">
                            <div class="row mb-4 national-fair-row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="ulusalFuarAdi">Fair Name</label>
                                        <input type="text" class="form-control ulusal-fuar-adi" id="ulusalFuarAdi">
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="ulusalKatilimYili">Year of Participation</label>
                                        <input type="text" class="form-control ulusal-katilim-yili" id="ulusalKatilimYili">
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row mb-4">
                        <div class="col-12 text-end">
                            <button type="button" class="btn btn-dark" id="addNationalFair">Add New</button>
                        </div>
                    </div>

                    <!-- International Fairs Section -->
                    <div class="section-title mb-3">Participation of your company in international fairs</div>
                    <div id="internationalFairsContainer">
                        <div class="form-row-container">
                            <div class="row mb-4 international-fair-row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="uluslararasiFuarAdi">Fair Name</label>
                                        <input type="text" class="form-control uluslararasi-fuar-adi" id="uluslararasiFuarAdi">
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="uluslararasiKatilimYili">Year of Participation</label>
                                        <input type="text" class="form-control uluslararasi-katilim-yili" id="uluslararasiKatilimYili">
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row mb-4">
                        <div class="col-12 text-end">
                            <button type="button" class="btn btn-dark" id="addInternationalFair">Add New</button>
                        </div>
                    </div>
                    <!-- Terms and Captcha -->
                     <div class="row mb-4">
                        <div class="col-12">
                            <div class="onay-kutusu-okf-1">
                                <label>
                                    <input type="checkbox" id="kabulEdiyorum" />
                                    <span>
                                        <a href="#" onclick="event.preventDefault(); bootstrap.Modal.getOrCreateInstance(document.getElementById('privacyModal')).show();">I have read and accept the Information Text and Privacy Policy.</a>
                                    </span>
                                </label>
                            </div>
                        </div>
                    </div>
                    <!-- Privacy Policy Modal -->
        <div class="modal fade" id="privacyModal" tabindex="-1" aria-labelledby="privacyModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-lg modal-dialog-scrollable">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="privacyModalLabel">PRIVACY POLICY AND WEBSITE TERMS OF USE</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
