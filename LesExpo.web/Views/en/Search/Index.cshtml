@{
    ViewData["Title"] = "Search";
    ViewData["Description"] = "LES-EXPO content search";
    ViewData["Keywords"] = "LES-EXPO, search, content";
}

@section Styles {
    <link rel="stylesheet" href="~/css/search.css">
    <style>
        .main-header {
            background-color: #0c243d;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
            height: 18%;
        }
    </style>
    }

<div class="search-page">
    <div class="container">
        <!-- Search Header -->
        <div class="search-header">
            <h1><i class="fas fa-search"></i> Search</h1>
            <p class="search-subtitle">Search through LES-EXPO content</p>
            
            <div class="search-box">
                <input type="text" 
                       id="searchInput" 
                       class="search-input" 
                       placeholder="Search... (e.g: Exhibition Area, Transportation)" 
                       value="@ViewBag.SearchTerm"
                       autocomplete="off">
                <div class="search-icon">
                    <i class="fas fa-search"></i>
                </div>
                <div id="searchSpinner" class="search-spinner" style="display: none;">
                    <i class="fas fa-spinner fa-spin"></i>
                </div>
            </div>
        </div>

        <!-- Search Stats -->
        <div class="search-filters">
            <div class="search-stats">
                <span id="searchStats" class="stats-text">Loading search results...</span>
            </div>
        </div>

        <!-- Search Results -->
        <div class="search-results-container">
            <div id="searchResults" class="search-results">
                <!-- Results will be populated by JavaScript -->
            </div>

            <!-- Loading State -->
            <div id="loadingState" class="loading-state">
                <div class="loading-spinner">
                    <i class="fas fa-spinner fa-spin"></i>
                    <p>Loading content...</p>
                </div>
            </div>

            <!-- No Results State -->
            <div id="noResultsState" class="no-results-state" style="display: none;">
                <div class="no-results-content">
                    <i class="fas fa-search"></i>
                    <h3>No Results Found</h3>
                    <p>No content found matching your search. Try different terms.</p>
                    <div class="search-suggestions">
                        <p><strong>Suggestions:</strong></p>
                        <div class="suggestion-tags">
                            <span class="suggestion-tag" onclick="performSuggestionSearch('Exhibition')">Exhibition</span>
                            <span class="suggestion-tag" onclick="performSuggestionSearch('Transportation')">Transportation</span>
                            <span class="suggestion-tag" onclick="performSuggestionSearch('Visitor')">Visitor</span>
                            <span class="suggestion-tag" onclick="performSuggestionSearch('Exhibitor')">Exhibitor</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Error State -->
            <div id="errorState" class="error-state" style="display: none;">
                <div class="error-content">
                    <i class="fas fa-exclamation-triangle"></i>
                    <h3>An Error Occurred</h3>
                    <p>There was a problem performing the search. Please try again.</p>
                    <button onclick="location.reload()" class="retry-button">
                        <i class="fas fa-redo"></i> Try Again
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/fuse.js@6.6.2"></script>
    <script src="~/js/fuse-search.js"></script>
} 