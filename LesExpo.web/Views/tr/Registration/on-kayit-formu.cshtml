@model LesExpo.Models.ViewModels.RegistrationVM
@{
    ViewData["Title"] = "Ön Kayıt Formu - LESEXPO";
    ViewData["Description"] = "LESEXPO Ön Kayıt Formu";
    ViewData["Keywords"] = "LESEXPO, Ön Kayıt, Fuar";
    ViewData["Author"] = "LESEXPO";
    ViewData["CanonicalUrl"] = SD.siteUrl + "/tr/on-kayit-formu";
    ViewData["AlternateUrls"] = new string[] { SD.siteUrl + "/en/on-kayit-formu" };
}

@section Styles{
    <link rel="stylesheet" href="~/css/on-kayit-formu.css">
    <link rel="stylesheet" href="~/css/online-bilet.css">
        <style>
            .banner {
                position: relative;
                background-image: url('/images/LES2.jpg');
                /* Görselin yolu */
                background-size: cover;
                background-position: center;
                height: 300px;
                /* Yüksekliği isteğe göre ayarlayın */
                color: white;
                font-family: Arial, sans-serif;
            align-items: center;
            text-align: center;
        }

        .banner-yazi {
            position: relative;
            font-size: 48px;
            font-weight: bold;
            padding-top: 180px;
        }
        
        .alert {
            padding: 15px;
            margin-bottom: 20px;
            border: 1px solid transparent;
            border-radius: 4px;
        }

        .alert-success {
            color: #3c763d;
            background-color: #dff0d8;
            border-color: #d6e9c6;
        }

        .alert-danger {
            color: #a94442;
            background-color: #f2dede;
            border-color: #ebccd1;
        }

        .text-danger {
            color: #dc3545;
            font-size: 0.875rem;
            margin-top: 5px;
            display: block;
        }
    </style>
}
@{
    ViewData["Title"] = "Ön Kayıt Formu - LESEXPO";
    ViewData["Description"] = "LESEXPO Ön Kayıt Formu";
    ViewData["Keywords"] = "LESEXPO, Ön Kayıt, Fuar";
    ViewData["Author"] = "LESEXPO";
}

    <div class="banner">
        <div class="banner-yazi">LES-EXPO</div>
        <div class="breadcrumb-1 mt-1">
            <a asp-controller="Home" asp-action="Index">Ana Sayfa</a> /
            <a asp-controller="Registration" asp-action="OnKayitFormu">Ön Kayıt Formu</a>
        </div>
    </div>

        <div class="container my-5">
            <div class="form-container">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success" role="alert">
                        @TempData["Success"]
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger" role="alert">
                        @TempData["Error"]
                    </div>
                }
                <form asp-controller="Registration" asp-action="OnKayitFormu" method="post">
                    @Html.AntiForgeryToken()
                    <!-- First Row -->
                    <div class="row mb-4">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="SirketAdi">Şirket Adınız *</label>
                                <input asp-for="SirketAdi" class="form-control" required>
                                <span asp-validation-for="SirketAdi" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="AdSoyad">Adınız Soyadınız *</label>
                                <input asp-for="AdSoyad" class="form-control" required>
                                <span asp-validation-for="AdSoyad" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Gorev">Göreviniz *</label>
                                <input asp-for="Gorev" class="form-control" required>
                                <span asp-validation-for="Gorev" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <!-- Second Row -->
                    <div class="row mb-4">
                        <div class="col-12">
                            <div class="form-group">
                                <label asp-for="SirketAdresi">Şirket Adresiniz *</label>
                                <textarea asp-for="SirketAdresi" class="form-control" rows="3" required></textarea>
                                <span asp-validation-for="SirketAdresi" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <!-- Third Row -->
                    <div class="row mb-4">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Ulke">Ülke *</label>
                                <select asp-for="Ulke" class="form-select" id="ulke" required>
                                    <option value="">Lütfen Seçiniz</option>
                                </select>
                                <span asp-validation-for="Ulke" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Sehir">Şehir *</label>
                                <select asp-for="Sehir" class="form-select" id="sehir" required>
                                    <option value="">Lütfen Önce Ülke Seçiniz</option>
                                </select>
                                <span asp-validation-for="Sehir" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Telefon">Telefon *</label>
                                <div class="input-group">
                                    <input asp-for="Telefon" type="tel" class="form-control" id="telefon" placeholder="+90 501 234 56 78" required>
                                </div>
                                <span asp-validation-for="Telefon" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <!-- Fourth Row -->
                    <div class="row mb-4">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Email">E-Posta Adresiniz *</label>
                                <input asp-for="Email" type="email" class="form-control" required>
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="WebSitesi">Web Sitesi Adresiniz</label>
                                <input asp-for="WebSitesi" type="url" class="form-control">
                                <span asp-validation-for="WebSitesi" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="FaaliyetAlani">Faaliyet Alanınız *</label>
                                <select asp-for="FaaliyetAlani" class="form-select" id="FaaliyetAlani" required>
                                    <option value="">Lütfen Seçiniz</option>
                                </select>
                                <span asp-validation-for="FaaliyetAlani" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <!-- Fifth Row -->
                    <div class="row mb-4">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="UrunGrubu">Ürün Grubunuzu Giriniz *</label>
                                <input asp-for="UrunGrubu" type="text" class="form-control" required>
                                <span asp-validation-for="UrunGrubu" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Markalar">Markalarınızı Giriniz *</label>
                                <input asp-for="Markalar" type="text" class="form-control" required>
                                <span asp-validation-for="Markalar" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="IstenenMetrekare">Ayırtmak İstediğiniz Metrekareyi Giriniz *</label>
                                <input asp-for="IstenenMetrekare" type="text" class="form-control" required>
                                <span asp-validation-for="IstenenMetrekare" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                    

                    <!-- Sixth Row -->
                    <div class="row mb-4">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>Firmanızı Ziyaret Etmemizi İster Misiniz? *</label>
                                <div class="radio-group">
                                    <div class="form-check form-check-inline">
                                        <input asp-for="FirmaZiyareti" class="form-check-input" type="radio" id="ziyaretEvet"
                                            value="evet" required>
                                        <label class="form-check-label" for="ziyaretEvet">Evet</label>
                                    </div>
                                    <div class="form-check form-check-inline">
                                        <input asp-for="FirmaZiyareti" class="form-check-input" type="radio" id="ziyaretHayir"
                                            value="hayir">
                                        <label class="form-check-label" for="ziyaretHayir">Hayır</label>
                                    </div>
                                </div>
                                <span asp-validation-for="FirmaZiyareti" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>Fuar Katılım Hakkında Ayrıntılı Bilgi *</label>
                                <div class="radio-group-form">
                                    <div class="form-check form-check-inline">
                                        <input asp-for="FuarKatilim" class="form-check-input" type="radio"
                                            id="katilimIstiyorum" value="istiyorum" required>
                                        <label class="form-check-label" for="katilimIstiyorum">İstiyorum</label>
                                    </div>
                                    <div class="form-check form-check-inline">
                                        <input asp-for="FuarKatilim" class="form-check-input" type="radio"
                                            id="katilimIstemiyorum" value="istemiyorum">
                                        <label class="form-check-label" for="katilimIstemiyorum">İstemiyorum</label>
                                    </div>
                                </div>
                                <span asp-validation-for="FuarKatilim" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="KurulusTarihi">Firmanızın Kuruluş Tarihi *</label>
                                <input asp-for="KurulusTarihi" type="date" class="form-control" placeholder="GG-AA-YYYY" required>
                                <span asp-validation-for="KurulusTarihi" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <!-- Seventh Row -->
                    <div class="row mb-4">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="AktiviteTuru">Firmanızın Aktivite Türü *</label>
                                <select asp-for="AktiviteTuru" class="form-select" required>
                                    <option value="">Seçiniz</option>
                                    <option value="uretici">Üretici</option>
                                    <option value="ithalatci">İthalatçı</option>
                                    <option value="ihracatci">İhracatçı</option>
                                    <option value="distribütor">Distribütör</option>
                                    <option value="toptanci">Toptancı</option>
                                    <option value="perakendeci">Perakendeci</option>
                                </select>
                                <span asp-validation-for="AktiviteTuru" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="IhracatCirosu">Firmanızın İhracat Cirosu *</label>
                                <div class="input-group">
                                    <span class="input-group-text">USD</span>
                                    <input asp-for="IhracatCirosu" type="text" class="form-control" required>
                                </div>
                                <span asp-validation-for="IhracatCirosu" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="ToplamCiro">Firmanızın Toplam Cirosu *</label>
                                <div class="input-group">
                                    <span class="input-group-text">USD</span>
                                    <input asp-for="ToplamCiro" type="text" class="form-control" required>
                                </div>
                                <span asp-validation-for="ToplamCiro" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <!-- Eighth Row -->
                    <div class="row mb-4">
                        <div class="col-12">
                            <div class="form-group">
                                <label asp-for="PersonelSayisi">Firmanızda İstihdam Edilen Personel Sayısı *</label>
                                <input asp-for="PersonelSayisi" type="number" class="form-control" required>
                                <span asp-validation-for="PersonelSayisi" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <!-- National Fairs Section -->
                    <div class="section-title mb-3">Firmanızın Ulusal Fuarlara Katılımı</div>
                    <div id="nationalFairsContainer">
                        <div class="form-row-container">
                            <div class="row mb-4 national-fair-row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="ulusalFuarAdi">Fuar Adı</label>
                                        <input type="text" class="form-control ulusal-fuar-adi" id="ulusalFuarAdi">
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="ulusalKatilimYili">Katılım Yılı</label>
                                        <input type="text" class="form-control ulusal-katilim-yili" id="ulusalKatilimYili">
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row mb-4">
                        <div class="col-12 text-end">
                            <button type="button" class="btn btn-dark" id="addNationalFair">Yeni Ekle</button>
                        </div>
                    </div>

                    <!-- International Fairs Section -->
                    <div class="section-title mb-3">Firmanızın Uluslararası Fuarlara Katılımı</div>
                    <div id="internationalFairsContainer">
                        <div class="form-row-container">
                            <div class="row mb-4 international-fair-row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="uluslararasiFuarAdi">Fuar Adı</label>
                                        <input type="text" class="form-control uluslararasi-fuar-adi" id="uluslararasiFuarAdi">
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="uluslararasiKatilimYili">Katılım Yılı</label>
                                        <input type="text" class="form-control uluslararasi-katilim-yili" id="uluslararasiKatilimYili">
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row mb-4">
                        <div class="col-12 text-end">
                            <button type="button" class="btn btn-dark" id="addInternationalFair">Yeni Ekle</button>
                        </div>
                    </div>
                      <!-- Privacy Policy Modal -->
        <div class="modal fade" id="privacyModal" tabindex="-1" aria-labelledby="privacyModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-lg modal-dialog-scrollable">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="privacyModalLabel">GİZLİLİK POLİTİKASI VE İNTERNET SİTESİ KULLANIM KOŞULLARI</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="privacy-content">
                            <h4>GİZLİLİK POLİTİKASI VE İNTERNET SİTESİ KULLANIM KOŞULLARI</h4>
                            <p>Bu internet sitesini kullanmadan önce lütfen aşağıdaki maddeleri dikkatle okuyup inceleyiniz.</p>
                            <p>https://les-expo.com.tr/ alan adlı internet sitesi ("Site" veya "Internet Sitesi") KFA Fuarcılık A.Ş ("KFA")'ne aittir.</p>
                            <p>Bu İnternet Sitesini kullanmakla aşağıda yer alan Kullanıcı Sözleşmesini kabul etmektesiniz.</p>

                            <h5>1- Kabul</h5>
                            <p>Bu Siteyi ziyaret etmekle, işbu Gizlilik Politikası ve Kullanım Şartları'nı ("Sözleşme") açıklanan şartlar kapsamında hareket etmeyi ve bu koşullara uymayı kabul etmektesiniz.</p>
                            <p>KFA bu koşulları ve ayrıca yine işbu internet sitesinde yer alan Gizlilik Politikası dahil diğer her türlü bilgiyi zaman zaman ve gerekli gördüğü takdirde herhangi bir bildirimde bulunmaksızın değiştirme hakkını saklı tutmaktadır. Bu Sözleşmenin güncel haline ve Gizlilik Politikası'na her zaman internet sitesinden ulaşabilirsiniz. İşbu İnternet Sitesine giriş yapmanız, işbu Sözleşme'yi ve herhangi bir zamanda Sözleşme'de meydana gelebilecek olan değişiklikleri kabul ettiğiniz anlamına gelmektedir. İnternet Sitesi üzerinde her türlü kullanım ve tasarruf yetkisi KFA'ya aittir.</p>

                            <h5>2- Sorumluluk</h5>
                            <p>KFA, fiyatlar, düzenlenen fuarlar ve sunulan hizmetler üzerinde değişiklik yapma hakkını her zaman saklı tutar. İnternet sitesinin kullanımında kaynak kodunu bulmak veya elde etmek amacına yönelik herhangi bir başka işlemde bulunmayacağınızı, aksi halde ve 3. Kişiler nezdinde doğacak zararlardan sorumlu olacağınızı, hakkında hukuki ve cezai işlem yapılacağını peşinen kabul etmektesiniz.</p>

                            <h5>3- Yayınlanan Bilgiye Güven</h5>
                            <p>İnternet Sitesinde yer alan bilgiler tamamen genel bilgi niteliğinde olup, bu bilgilerin doğruluğu garanti edilmemektedir. İnternet Sitesinden edinilen bilgilere güvenden doğacak tüm sorumluluk tarafınıza aittir.</p>

                            <h5>4- Kişisel Veriler</h5>
                            <p>İnternet sitesine sunduğunuz kişisel bilgilerin işlenmesi, kaydedilmesi ve korunması hakkında bilgi edinmek için lütfen KVKK formlarımızı okuyunuz.</p>

                            <h5>5- Kişisel Olmayan Bilgiler</h5>
                            <p>Kişisel olmayan bilgiler, şahsen sizlerin tanımlanamayacağımız bilgilerdir. Örneğin; kullanım saatleri, Site'nin kullanıldığı lokasyon, incelenen sayfalar vb. bilgilerdir.</p>

                            <h5>6- Çerez (Cookie) Kullanımı</h5>
                            <p>Çerezler, Site'yi ziyaret ettiğiniz zaman bilgisayarınıza tercihlerinizi kaydeden küçük metin dosyalarıdır. Çerezler, alışveriş sepetinizde hangi ürünlerin olduğunu hatırlamak, web sitesine veya mobil uygulamaya tekrar giriş yaptığınızda sitenin sizi tanıması, ilginizi çekebilecek ilan ve reklamların en çok giriş yaptığınız sayfalarda yayınlanması gibi işlemlerde size en kaliteli hizmeti sağlamak için kullanılmaktadır.</p>

                            <h5>7- Ödeme Güvenliği</h5>
                            <p>Toplanan mali bilgiler satın aldığınız ürünleri size fatura etmek için kullanılmaktadır. Web sitesinde veya mobil uygulamada online ödemeli bir satın alma yaptığınızda size ait mali bilgilerin, işleminizi gerçekleştirmek için gerekli 3. şahıslara (bankalar, kredi kartı şirketleri vb.) verilmesini kabul etmektesiniz.</p>

                            <h5>8- Diğer İnternet Sitelerine Verilen Linkler</h5>
                            <p>Bu internet sitesinden üçüncü kişilere ait başka internet sitelerine link verilebilmektedir. KFA link verilen internet sitelerinde yer alan içerikten sorumlu değildir ve bunların doğruluğunu, kalitesini yahut güncelliğini kontrol etme yükümlülüğü bulunmamaktadır.</p>

                            <h5>9- Fikri Mülkiyet Hakları</h5>
                            <p>Bu internet sitesi ve tüm sayfaları ve bu internet uygulaması yazılımı ve içerisindeki tüm görsel eserler, tasarımlar, arayüzler, kullanıcı kontrolleri, süreçler, programlar ve yazılım bileşenlerin ve bunlarla sınırlı kalmaksızın her türlü hakkı münhasıran KFA, lisans veren veya diğer sağlayıcılara aittir.</p>

                            <h5>10- Zararların Tazmini</h5>
                            <p>Tarafınızca işbu hükümlerin ihlal edilmesi veya İnternet Sitesi'nin aykırı kullanılmasından doğacak her türlü talepten, sorumluluktan, zarardan, karardan, hükümden, kayıptan, masraftan veya ücretten (vekalet ücreti dahil olmak üzere) KFA'yi, iştiraklerini, lisans verenlerini ve bunların çalışanlarını, yöneticileri, temsilcilerini, tedarikçilerini ve haleflerini ari tutacağınızı ve zararları tazmin edeceğinizi kabul etmektesiniz.</p>

                            <h5>11- İletişim Bilgileri</h5>
                            <p>Sorularınız için info@les-expo.com e-mail adresini kullanınız.</p>

                            <h5>12- Uygulanacak Hukuk ve Uyuşmazlıkların Çözümü</h5>
                            <p>İşbu Sözleşmeye herhangi bir çelişkiye mahal vermeksizin Türk hukuku uygulanacak olup, ihtilafın karşılıklı müzakereler neticesinde çözümünün mümkün olmadığı hallerde söz konusu uyuşmazlık Bursa Mahkemeleri ve İcra Müdürlükleri nezdinde çözümlenecektir.</p>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Kapat</button>
                        <button type="button" class="btn btn-primary" id="acceptPrivacy">Kabul Ediyorum</button>
                    </div>
                </div>
            </div>
        </div>
                </form>
            </div>
        </div>

@section Scripts{
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/js/on-kayit-formu.js"></script>
    <script>
        // Form submission için ek JS
        document.addEventListener('DOMContentLoaded', function() {
            // Form submit olduğunda ulusal ve uluslararası fuarları topla
            document.querySelector('form').addEventListener('submit', function(e) {
                e.preventDefault();
                
                // Ulusal fuarları topla
                const ulusalFuarlar = [];
                document.querySelectorAll('.national-fair-row').forEach(function(row) {
                    const fuarAdi = row.querySelector('.ulusal-fuar-adi').value.trim();
                    const katilimYili = row.querySelector('.ulusal-katilim-yili').value.trim();
                    
                    if (fuarAdi && katilimYili) {
                        // Hidden input oluştur
                        const fuarAdiInput = document.createElement('input');
                        fuarAdiInput.type = 'hidden';
                        fuarAdiInput.name = 'UlusalFuarlar[' + ulusalFuarlar.length + '].FuarAdi';
                        fuarAdiInput.value = fuarAdi;
                        
                        const katilimYiliInput = document.createElement('input');
                        katilimYiliInput.type = 'hidden';
                        katilimYiliInput.name = 'UlusalFuarlar[' + ulusalFuarlar.length + '].KatilimYili';
                        katilimYiliInput.value = katilimYili;
                        
                        this.appendChild(fuarAdiInput);
                        this.appendChild(katilimYiliInput);
                        
                        ulusalFuarlar.push({ fuarAdi, katilimYili });
                    }
                }, this);
                
                // Uluslararası fuarları topla
                const uluslararasiFuarlar = [];
                document.querySelectorAll('.international-fair-row').forEach(function(row) {
                    const fuarAdi = row.querySelector('.uluslararasi-fuar-adi').value.trim();
                    const katilimYili = row.querySelector('.uluslararasi-katilim-yili').value.trim();
                    
                    if (fuarAdi && katilimYili) {
                        // Hidden input oluştur
                        const fuarAdiInput = document.createElement('input');
                        fuarAdiInput.type = 'hidden';
                        fuarAdiInput.name = 'UluslararasiFuarlar[' + uluslararasiFuarlar.length + '].FuarAdi';
                        fuarAdiInput.value = fuarAdi;
                        
                        const katilimYiliInput = document.createElement('input');
                        katilimYiliInput.type = 'hidden';
                        katilimYiliInput.name = 'UluslararasiFuarlar[' + uluslararasiFuarlar.length + '].KatilimYili';
                        katilimYiliInput.value = katilimYili;
                        
                        this.appendChild(fuarAdiInput);
                        this.appendChild(katilimYiliInput);
                        
                        uluslararasiFuarlar.push({ fuarAdi, katilimYili });
                    }
                }, this);
                
                // Formu gönder
                this.submit();
            });
        });
    </script>
}

