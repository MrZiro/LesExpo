@model LesExpo.Models.ViewModels.RegistrationVM
@{
    ViewData["Title"] = "Ön Kayıt Formu - LESEXPO";
    ViewData["Description"] = "LESEXPO Ön Kayıt Formu - Fuarımıza katılımcı olarak yer almak için ön kayıt formunu doldurabilirsiniz.";
    ViewData["Keywords"] = "LESEXPO, Ön Kayıt, Fuar";
    ViewData["Author"] = "LESEXPO";
    ViewData["CanonicalUrl"] = SD.siteUrl + "/tr/on-kayit-formu";
    ViewData["AlternateUrls"] = new string[] { SD.siteUrl + "/en/on-kayit-formu" };
}

@section Styles{
    <link rel="stylesheet" href="~/css/on-kayit-formu.css">
    <link rel="stylesheet" href="~/css/online-bilet.css">
        <style>
            .banner {
                position: relative;
                background-image: url('/images/LES2.jpg');
                /* Görselin yolu */
                background-size: cover;
                background-position: center;
                height: 300px;
                /* Yüksekliği isteğe göre ayarlayın */
                color: white;
                font-family: Arial, sans-serif;
            align-items: center;
            text-align: center;
        }

        .banner-yazi {
            position: relative;
            font-size: 48px;
            font-weight: bold;
            padding-top: 180px;
        }
        
        
    </style>
}
@{
    ViewData["Title"] = "Ön Kayıt Formu - LESEXPO";
    ViewData["Description"] = "LESEXPO Ön Kayıt Formu";
    ViewData["Keywords"] = "LESEXPO, Ön Kayıt, Fuar";
    ViewData["Author"] = "LESEXPO";
}

    <div class="banner">
        <div class="banner-yazi">LES-EXPO</div>
        <div class="breadcrumb-1 mt-1">
            <a asp-controller="Home" asp-action="Index">Ana Sayfa</a> /
            <a asp-controller="Registration" asp-action="OnKayitFormu">Ön Kayıt Formu</a>
        </div>
    </div>

        <div class="container my-5">
            <div class="form-container">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success" role="alert">
                        @TempData["Success"]
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger" role="alert">
                        @TempData["Error"]
                    </div>
                }
                <form method="post">
                    @Html.AntiForgeryToken()
                    <!-- First Row -->
                    <div class="row mb-4">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Registration.SirketAdi">Şirket Adınız *</label>
                                <input asp-for="Registration.SirketAdi" class="form-control" required>
                                <span asp-validation-for="Registration.SirketAdi" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Registration.AdSoyad">Adınız Soyadınız *</label>
                                <input asp-for="Registration.AdSoyad" class="form-control" required>
                                <span asp-validation-for="Registration.AdSoyad" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Registration.Gorev">Göreviniz *</label>
                                <input asp-for="Registration.Gorev" class="form-control" required>
                                <span asp-validation-for="Registration.Gorev" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <!-- Second Row -->
                    <div class="row mb-4">
                        <div class="col-12">
                            <div class="form-group">
                                <label asp-for="Registration.SirketAdresi">Şirket Adresiniz *</label>
                                <textarea asp-for="Registration.SirketAdresi" class="form-control" rows="3" required></textarea>
                                <span asp-validation-for="Registration.SirketAdresi" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <!-- Third Row -->
                    <div class="row mb-4">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Registration.Ulke">Ülke *</label>
                                <select asp-for="Registration.Ulke" class="form-select" id="ulke" required>
                                    <option value="">Lütfen Seçiniz</option>
                                </select>
                                <span asp-validation-for="Registration.Ulke" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Registration.Sehir">Şehir *</label>
                                <select asp-for="Registration.Sehir" class="form-select" id="sehir" required>
                                    <option value="">Lütfen Önce Ülke Seçiniz</option>
                                </select>
                                <span asp-validation-for="Registration.Sehir" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Registration.Telefon">Telefon *</label>
                                <div class="input-group">
                                    <input asp-for="Registration.Telefon" type="tel" class="form-control" id="telefon" placeholder="+90 501 234 56 78" required>
                                </div>
                                <span asp-validation-for="Registration.Telefon" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <!-- Fourth Row -->
                    <div class="row mb-4">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Registration.Email">E-Posta Adresiniz *</label>
                                <input asp-for="Registration.Email" type="email" class="form-control" required>
                                <span asp-validation-for="Registration.Email" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Registration.WebSitesi">Web Sitesi Adresiniz</label>
                                <input asp-for="Registration.WebSitesi" type="url" class="form-control">
                                <span asp-validation-for="Registration.WebSitesi" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Registration.FaaliyetAlani">Faaliyet Alanınız *</label>
                                <select asp-for="Registration.FaaliyetAlani" class="form-select" id="FaaliyetAlani" required>
                                    <option value="">Lütfen Seçiniz</option>
                                </select>
                                <span asp-validation-for="Registration.FaaliyetAlani" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <!-- Fifth Row -->
                    <div class="row mb-4">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Registration.UrunGrubu">Ürün Grubunuzu Giriniz *</label>
                                <input asp-for="Registration.UrunGrubu" type="text" class="form-control" required>
                                <span asp-validation-for="Registration.UrunGrubu" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Registration.Markalar">Markalarınızı Giriniz *</label>
                                <input asp-for="Registration.Markalar" type="text" class="form-control" required>
                                <span asp-validation-for="Registration.Markalar" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Registration.IstenenMetrekare">Ayırtmak İstediğiniz Metrekareyi Giriniz *</label>
                                <input asp-for="Registration.IstenenMetrekare" type="text" class="form-control" required>
                                <span asp-validation-for="Registration.IstenenMetrekare" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                    

                    <!-- Sixth Row -->
                    <div class="row mb-4">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>Firmanızı Ziyaret Etmemizi İster Misiniz? *</label>
                                <div class="radio-group">
                                    <div class="form-check form-check-inline">
                                        <input asp-for="Registration.FirmaZiyareti" class="form-check-input" type="radio" id="ziyaretEvet"
                                            value="evet" required>
                                        <label class="form-check-label" for="ziyaretEvet">Evet</label>
                                    </div>
                                    <div class="form-check form-check-inline">
                                        <input asp-for="Registration.FirmaZiyareti" class="form-check-input" type="radio" id="ziyaretHayir"
                                            value="hayir">
                                        <label class="form-check-label" for="ziyaretHayir">Hayır</label>
                                    </div>
                                </div>
                                <span asp-validation-for="Registration.FirmaZiyareti" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>Fuar Katılım Hakkında Ayrıntılı Bilgi *</label>
                                <div class="radio-group-form">
                                    <div class="form-check form-check-inline">
                                        <input asp-for="Registration.FuarKatilim" class="form-check-input" type="radio"
                                            id="katilimIstiyorum" value="istiyorum" required>
                                        <label class="form-check-label" for="katilimIstiyorum">İstiyorum</label>
                                    </div>
                                    <div class="form-check form-check-inline">
                                        <input asp-for="Registration.FuarKatilim" class="form-check-input" type="radio"
                                            id="katilimIstemiyorum" value="istemiyorum">
                                        <label class="form-check-label" for="katilimIstemiyorum">İstemiyorum</label>
                                    </div>
                                </div>
                                <span asp-validation-for="Registration.FuarKatilim" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Registration.KurulusTarihi">Firmanızın Kuruluş Tarihi *</label>
                                <input asp-for="Registration.KurulusTarihi" type="date" class="form-control" placeholder="GG-AA-YYYY" required>
                                <span asp-validation-for="Registration.KurulusTarihi" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <!-- Seventh Row -->
                    <div class="row mb-4">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Registration.AktiviteTuru">Firmanızın Aktivite Türü *</label>
                                <select asp-for="Registration.AktiviteTuru" class="form-select" required>
                                    <option value="">Seçiniz</option>
                                    <option value="uretici">Üretici</option>
                                    <option value="ithalatci">İthalatçı</option>
                                    <option value="ihracatci">İhracatçı</option>
                                    <option value="distribütor">Distribütör</option>
                                    <option value="toptanci">Toptancı</option>
                                    <option value="perakendeci">Perakendeci</option>
                                </select>
                                <span asp-validation-for="Registration.AktiviteTuru" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Registration.IhracatCirosu">Firmanızın İhracat Cirosu *</label>
                                <div class="input-group">
                                    <span class="input-group-text">USD</span>
                                    <input asp-for="Registration.IhracatCirosu" type="text" class="form-control" required>
                                </div>
                                <span asp-validation-for="Registration.IhracatCirosu" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Registration.ToplamCiro">Firmanızın Toplam Cirosu *</label>
                                <div class="input-group">
                                    <span class="input-group-text">USD</span>
                                    <input asp-for="Registration.ToplamCiro" type="text" class="form-control" required>
                                </div>
                                <span asp-validation-for="Registration.ToplamCiro" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <!-- Eighth Row -->
                    <div class="row mb-4">
                        <div class="col-12">
                            <div class="form-group">
                                <label asp-for="Registration.PersonelSayisi">Firmanızda İstihdam Edilen Personel Sayısı *</label>
                                <input asp-for="Registration.PersonelSayisi" type="number" class="form-control" required>
                                <span asp-validation-for="Registration.PersonelSayisi" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <!-- National Fairs Section -->
                    <div class="section-title mb-3">Firmanızın Ulusal Fuarlara Katılımı</div>
                    <div id="nationalFairsContainer">
                        <div class="form-row-container">
                            <div class="row mb-4 national-fair-row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="ulusalFuarAdi">Fuar Adı</label>
                                        <input type="text" class="form-control ulusal-fuar-adi" id="ulusalFuarAdi">
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="ulusalKatilimYili">Katılım Yılı</label>
                                        <input type="text" class="form-control ulusal-katilim-yili" id="ulusalKatilimYili">
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row mb-4">
                        <div class="col-12 text-end">
                            <button type="button" class="btn btn-dark" id="addNationalFair">Yeni Ekle</button>
                        </div>
                    </div>

                    <!-- International Fairs Section -->
                    <div class="section-title mb-3">Firmanızın Uluslararası Fuarlara Katılımı</div>
                    <div id="internationalFairsContainer">
                        <div class="form-row-container">
                            <div class="row mb-4 international-fair-row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="uluslararasiFuarAdi">Fuar Adı</label>
                                        <input type="text" class="form-control uluslararasi-fuar-adi" id="uluslararasiFuarAdi">
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="uluslararasiKatilimYili">Katılım Yılı</label>
                                        <input type="text" class="form-control uluslararasi-katilim-yili" id="uluslararasiKatilimYili">
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row mb-4">
                        <div class="col-12 text-end">
                            <button type="button" class="btn btn-dark" id="addInternationalFair">Yeni Ekle</button>
                        </div>
                    </div>


                    
                    <!-- Terms and Captcha -->
                     <div class="row mb-4">
                        <div class="col-12">
                            <div class="onay-kutusu-okf-1">
                                <label>
                                    <input type="checkbox" id="kabulEdiyorum" />
                                    <span>
                                        <a href="#" onclick="event.preventDefault(); bootstrap.Modal.getOrCreateInstance(document.getElementById('privacyModal')).show();">Bilgilendirme Metni ve Gizlilik Politikasını okudum ve kabul ediyorum.</a>
                                    </span>
                                </label>
                            </div>
                        </div>
                     </div>
                     <div class="row mb-4">
                        <div class="col-12">
                            <div class="onay-kutusu-okf-1">
                                <button class="btn-okf-1" onclick="butonKontrolOkf1()">Yerinizi Ayırtın</button>
                            </div>
                        </div>
                     </div>
                </form>
            </div>
        </div>   
                    
        <!-- Privacy Policy Modal -->
        <div class="modal fade" id="privacyModal" tabindex="-1" aria-labelledby="privacyModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-lg modal-dialog-scrollable">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="privacyModalLabel">GİZLİLİK POLİTİKASI VE WEB SİTESİ KULLANIM ŞARTLARI</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                           <div class="privacy-content">
                            <h4>GİZLİLİK POLİTİKASI VE WEB SİTESİ KULLANIM ŞARTLARI</h4>
                            <p>Lütfen bu web sitesini kullanmadan önce aşağıdaki maddeleri dikkatlice okuyup inceleyiniz.</p>
                            <p>https://www.les-expo.com alan adına sahip web sitesi ("Site" veya "Web Sitesi") KFA Fuarcılık A.Ş'ye ("KFA") aittir.</p>
                            <p>Bu Web Sitesini kullanarak, aşağıdaki Kullanıcı Sözleşmesini kabul etmiş olursunuz.</p>

                            <h5>1- Kabul</h5>
                            <p>Bu Siteyi ziyaret ederek, bu Gizlilik Politikası ve Kullanım Şartlarında ("Sözleşme") belirtilen şartlar kapsamında hareket etmeyi ve bu koşullara uymayı kabul edersiniz.</p>
                            <p>KFA, Gizlilik Politikası dahil olmak üzere bu şartları ve diğer bilgileri herhangi bir bildirimde bulunmaksızın zaman zaman değiştirme hakkını saklı tutar. Bu Sözleşme ve Gizlilik Politikasının güncel versiyonuna her zaman web sitesinden erişebilirsiniz. Bu Web Sitesine erişiminiz, bu Sözleşmeyi ve Sözleşmede herhangi bir zamanda meydana gelebilecek değişiklikleri kabul ettiğiniz anlamına gelir. Web Sitesi üzerindeki tüm kullanım ve tasarruf hakları KFA'ya aittir.</p>

                            <h5>2- Sorumluluk</h5>
                            <p>KFA, fiyatlar, düzenlenen fuarlar ve sunulan hizmetlerde değişiklik yapma hakkını her zaman saklı tutar. Web sitesinin kullanımında kaynak kodunu bulmaya veya elde etmeye yönelik başka bir eylemde bulunmayacağınızı, üçüncü kişilerden doğabilecek zararlardan sorumlu olacağınızı ve yasal ve cezai işlemlerin başlatılacağını önceden kabul edersiniz.</p>

                            <h5>3- Yayınlanan Bilgilere Güven</h5>
                            <p>Web Sitesindeki bilgiler tamamen genel bilgilerdir ve bu bilgilerin doğruluğu garanti edilmez. Web Sitesinden elde edilen bilgilere güvenmekten doğacak tüm sorumluluk size aittir.</p>

                            <h5>4- Kişisel Veriler</h5>
                            <p>Web sitesine sağladığınız kişisel bilgilerin işlenmesi, kaydedilmesi ve korunması hakkında bilgi için lütfen KVKK formlarımızı okuyunuz.</p>

                            <h5>5- Kişisel Olmayan Bilgiler</h5>
                            <p>Kişisel olmayan bilgiler, sizi kişisel olarak tanımlayamayan bilgilerdir. Örneğin; kullanım saatleri, Sitenin kullanıldığı konum, görüntülenen sayfalar vb. bilgiler.</p>

                            <h5>6- Çerez Kullanımı</h5>
                            <p>Çerezler, Siteyi ziyaret ettiğinizde bilgisayarınızda tercihlerinizi kaydeden küçük metin dosyalarıdır. Çerezler, alışveriş sepetinizde hangi ürünlerin olduğunu hatırlamak, web sitesine veya mobil uygulamaya tekrar giriş yaptığınızda sizi tanımak ve en çok ziyaret ettiğiniz sayfalarda ilginizi çekebilecek reklamları yayınlama gibi işlemlerde size en kaliteli hizmeti sunmak için kullanılır.</p>

                            <h5>7- Ödeme Güvenliği</h5>
                            <p>Toplanan finansal bilgiler, satın aldığınız ürünlerin faturalandırılması için kullanılır. Web sitesinde veya mobil uygulamada çevrimiçi ödeme satın alımı yaptığınızda, finansal bilgilerinizin işleminizi tamamlamak için gerekli üçüncü taraflara (bankalar, kredi kartı şirketleri vb.) verileceğini kabul edersiniz.</p>

                            <h5>8- Diğer Web Sitelerine Bağlantılar</h5>
                            <p>Bu web sitesinden üçüncü taraflara ait diğer web sitelerine bağlantılar sağlanabilir. KFA, bağlantı verilen web sitelerinin içeriğinden sorumlu değildir ve bunların doğruluğunu, kalitesini veya güncelliğini kontrol etme yükümlülüğü yoktur.</p>

                            <h5>9- Fikri Mülkiyet Hakları</h5>
                            <p>Bu web sitesi ve tüm sayfaları ve bu web uygulama yazılımı ve içerdiği tüm görsel çalışmalar, tasarımlar, arayüzler, kullanıcı kontrolleri, süreçler, programlar ve yazılım bileşenleri ve bunlarla sınırlı olmamak üzere tüm haklar, münhasıran KFA'ya, lisans verenlere veya diğer sağlayıcılara aittir.</p>

                            <h5>10- Tazminat</h5>
                            <p>Bu hükümlerin ihlalinden veya Web Sitesinin yanlış kullanımından kaynaklanan herhangi bir talep, sorumluluk, hasar, karar, yargı, kayıp, gider veya ücretten (avukatlık ücretleri dahil) KFA'yı, bağlı kuruluşlarını, lisans verenlerini ve bunların çalışanlarını, yöneticilerini, temsilcilerini, tedarikçilerini ve haleflerini tazmin etmeyi kabul edersiniz.</p>

                            <h5>11- İletişim Bilgileri</h5>
                            <p>Lütfen sorularınız için info@les-expo.com e-posta adresini kullanınız.</p>

                            <h5>12- Uygulanacak Hukuk ve Uyuşmazlık Çözümü</h5>
                            <p>Bu Sözleşmeye herhangi bir çelişki olmaksızın Türk hukuku uygulanacak olup, karşılıklı görüşmeler sonucunda uyuşmazlığın çözümlenememesi durumunda ilgili uyuşmazlık Bursa Mahkemeleri ve İcra Daireleri önünde çözümlenecektir.</p>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Kapat</button>
                        <button type="button" class="btn btn-primary" id="acceptPrivacy">Kabul Ediyorum</button>
                    </div>
                </div>
            </div>
        </div>
@section Scripts{
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/js/on-kayit-formu.js"></script>
    <script>
        // Form submission için ek JS
        document.addEventListener('DOMContentLoaded', function() {
            // Form submit olduğunda ulusal ve uluslararası fuarları topla
            document.querySelector('form').addEventListener('submit', function(e) {
                e.preventDefault();
                
                //   Ulusal fuarları topla 
                const ulusalFuarlar = [];
                document.querySelectorAll('.national-fair-row').forEach(function(row) {
                    const fuarAdi = row.querySelector('.ulusal-fuar-adi').value.trim();
                    const katilimYili = row.querySelector('.ulusal-katilim-yili').value.trim();
                    
                    if (fuarAdi && katilimYili) {
                        // Hidden input oluştur
                        const fuarAdiInput = document.createElement('input');
                        fuarAdiInput.type = 'hidden';
                        fuarAdiInput.name = 'UlusalFuarlar[' + ulusalFuarlar.length + '].FuarAdi';
                        fuarAdiInput.value = fuarAdi;
                        
                        const katilimYiliInput = document.createElement('input');
                        katilimYiliInput.type = 'hidden';
                        katilimYiliInput.name = 'UlusalFuarlar[' + ulusalFuarlar.length + '].KatilimYili';
                        katilimYiliInput.value = katilimYili;
                        
                        this.appendChild(fuarAdiInput);
                        this.appendChild(katilimYiliInput);
                        
                        ulusalFuarlar.push({ fuarAdi, katilimYili });
                    }
                }, this);
                
                // Uluslararası fuarları topla
                const uluslararasiFuarlar = [];
                document.querySelectorAll('.international-fair-row').forEach(function(row) {
                    const fuarAdi = row.querySelector('.uluslararasi-fuar-adi').value.trim();
                    const katilimYili = row.querySelector('.uluslararasi-katilim-yili').value.trim();
                    
                    if (fuarAdi && katilimYili) {
                        // Hidden input oluştur
                        const fuarAdiInput = document.createElement('input');
                        fuarAdiInput.type = 'hidden';
                        fuarAdiInput.name = 'UluslararasiFuarlar[' + uluslararasiFuarlar.length + '].FuarAdi';
                        fuarAdiInput.value = fuarAdi;
                        
                        const katilimYiliInput = document.createElement('input');
                        katilimYiliInput.type = 'hidden';
                        katilimYiliInput.name = 'UluslararasiFuarlar[' + uluslararasiFuarlar.length + '].KatilimYili';
                        katilimYiliInput.value = katilimYili;
                        
                        this.appendChild(fuarAdiInput);
                        this.appendChild(katilimYiliInput);
                        
                        uluslararasiFuarlar.push({ fuarAdi, katilimYili });
                    }
                }, this);
                
                // Formu gönder
                this.submit();
            });
        });
    </script>
}

