@{
    ViewData["Title"] = "Sıkça Sorulan Sorular";
    ViewData["Description"] = "Sıkça Sorulan Sorular";
    ViewData["Keywords"] = "Sıkça Sorulan Sorular";
    ViewData["CanonicalUrl"] = "~/tr/sikca-sorulan-sorular";
    ViewData["AlternateUrls"] = new string[] { "~/en/faq" };
}
@section Styles {

  <link rel="stylesheet" href="~/css/sss.css">
    <style>
    .banner {
      position: relative;
      background-image: url('/images/LES4.jpg');
      /* Görselin yolu */
      background-size: cover;
      background-position: center;
      height: 300px;
      /* Yüksekliği isteğe göre ayarlayın */
      color: white;
      font-family: Arial, sans-serif;
      align-items: center;
      text-align: center;
    }

    .banner-yazi {
      position: relative;
      font-size: 48px;
      font-weight: bold;
      padding-top: 178px;
    }
    .pharmaist-section{text-align: center;}

  </style>
}




<div class="banner">
    <div class="banner-yazi">LES-EXPO</div>
    <div class="breadcrumb-1">
        <a href="/tr">Ana Sayfa</a> /
        <a href="/tr/sikca-sorulan-sorular">Sıkça Sorulan Sorular</a>
    </div>
  </div>


        <div class="container main-container">
            <div class="row">
                <!-- Sidebar -->
            <partial name="Components/AboutUs/_Sidebar" />
                <!-- Main content -->
                <div class=" content-area">
                    <div class="container-sss faq-container">
                        <div class="row">
                            <div class="col-12">
                                <h1 class="faq-title">Ziyaretçiler Tarafından Sıkça Sorulan Sorular (S.S.S.)</h1>
                                <div class="divider"></div>
                            </div>
                        </div>

                        <div class="row position-relative">
                            <div class="col-lg-9">
                                <div class="accordion" id="faqAccordion">
                                    <!-- FAQ Item 1 -->
                                    <div class="accordion-item">
                                        <h2 class="accordion-header" id="headingOne">
                                            <button class="accordion-button collapsed" type="button"
                                                data-bs-toggle="collapse" data-bs-target="#collapseOne"
                                                aria-expanded="false" aria-controls="collapseOne">
                                                Ziyaretçi Kaydını nasıl yapabilirim?
                                            </button>
                                        </h2>
                                        <div id="collapseOne" class="accordion-collapse collapse"
                                            aria-labelledby="headingOne" data-bs-parent="#faqAccordion">
                                            <div class="accordion-body">
                                                Ziyaretçi kaydınızı web sitemizin ana sayfasındaki "Online Bilet"
                                                bölümünden çevrimiçi olarak yapabilirsiniz. Ayrıca etkinlik günü girişte
                                                de kayıt yaptırabilirsiniz, ancak çevrimiçi kayıt daha hızlı giriş
                                                sağlayacaktır.
                                            </div>
                                        </div>
                                    </div>

                                    <!-- FAQ Item 2 -->
                                    <div class="accordion-item">
                                        <h2 class="accordion-header" id="headingTwo">
                                            <button class="accordion-button collapsed" type="button"
                                                data-bs-toggle="collapse" data-bs-target="#collapseTwo"
                                                aria-expanded="false" aria-controls="collapseTwo">
                                                Fuar giriş ücreti nedir?
                                            </button>
                                        </h2>
                                        <div id="collapseTwo" class="accordion-collapse collapse"
                                            aria-labelledby="headingTwo" data-bs-parent="#faqAccordion">
                                            <div class="accordion-body">
                                                Fuarımıza giriş ücreti 200 TL'dir.
                                            </div>
                                        </div>
                                    </div>

                                    <!-- FAQ Item 3 -->
                                    <div class="accordion-item">
                                        <h2 class="accordion-header" id="headingThree">
                                            <button class="accordion-button collapsed" type="button"
                                                data-bs-toggle="collapse" data-bs-target="#collapseThree"
                                                aria-expanded="false" aria-controls="collapseThree">
                                                Fuarın Ziyaret Saatleri Neler?
                                            </button>
                                        </h2>
                                        <div id="collapseThree" class="accordion-collapse collapse"
                                            aria-labelledby="headingThree" data-bs-parent="#faqAccordion">
                                            <div class="accordion-body">
                                                Fuar hafta içi 10:00-18:00, hafta sonu 10:00-20:00 saatleri arasında
                                                ziyarete açıktır. Son giriş kapanıştan 1 saat öncedir.
                                            </div>
                                        </div>
                                    </div>

                                    <!-- FAQ Item 4 -->
                                    <div class="accordion-item">
                                        <h2 class="accordion-header" id="headingFour">
                                            <button class="accordion-button collapsed" type="button"
                                                data-bs-toggle="collapse" data-bs-target="#collapseFour"
                                                aria-expanded="false" aria-controls="collapseFour">
                                                Fuar Yerleşim Planını nereden bulabilirim?
                                            </button>
                                        </h2>
                                        <div id="collapseFour" class="accordion-collapse collapse"
                                            aria-labelledby="headingFour" data-bs-parent="#faqAccordion">
                                            <div class="accordion-body">
                                                Fuar yerleşim planını web sitemizin "Fuar Alanı" bölümünden
                                                indirebilirsiniz. Ayrıca fuar girişinde ücretsiz olarak basılı plan
                                                temin edebilirsiniz.
                                            </div>
                                        </div>
                                    </div>

                                    <!-- FAQ Item 6 -->
                                    <div class="accordion-item">
                                        <h2 class="accordion-header" id="headingSix">
                                            <button class="accordion-button collapsed" type="button"
                                                data-bs-toggle="collapse" data-bs-target="#collapseSix"
                                                aria-expanded="false" aria-controls="collapseSix">
                                                Katılımcı Listesi'ne nereden ulaşabilirim?
                                            </button>
                                        </h2>
                                        <div id="collapseSix" class="accordion-collapse collapse"
                                            aria-labelledby="headingSix" data-bs-parent="#faqAccordion">
                                            <div class="accordion-body">
                                                Katılımcı listesine web sitemizin "Katılımcı Listesi" bölümünden
                                                ulaşabilirsiniz. Liste düzenli olarak güncellenmektedir.
                                            </div>
                                        </div>
                                    </div>

                                    <!-- FAQ Item 7 -->
                                    <div class="accordion-item">
                                        <h2 class="accordion-header" id="headingSeven">
                                            <button class="accordion-button collapsed" type="button"
                                                data-bs-toggle="collapse" data-bs-target="#collapseSeven"
                                                aria-expanded="false" aria-controls="collapseSeven">
                                                Fuar Alanı tam olarak nerede yer alıyor?
                                            </button>
                                        </h2>
                                        <div id="collapseSeven" class="accordion-collapse collapse"
                                            aria-labelledby="headingSeven" data-bs-parent="#faqAccordion">
                                            <div class="accordion-body">
                                                Fuar, İstanbul Fuar Merkezi'nde gerçekleştirilecektir. Adres: Yeşilköy
                                                Istanbul, Fuar Merkezi, 34149 Bakırköy/İstanbul. Toplu taşıma ve özel
                                                araç ile ulaşım bilgilerini "Ulaşım" sayfamızda bulabilirsiniz.
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-lg-3 d-none d-lg-block">
                                <div class="question-marks">
                                    <div class="question-mark question-mark-1">?</div>
                                    <div class="question-mark question-mark-2">?</div>
                                    <div class="question-mark question-mark-3">?</div>
                                    <div class="question-mark question-mark-4">?</div>
                                </div>
                            </div>

                            <div class="right-border d-none d-lg-block"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- Sidebar mobile toggle button -->
        <button class="sidebar-toggle-button d-md-none">
            <i class="fas fa-bars"></i>
        </button>

