@{
    ViewData["Title"] = "LES Insights";
    ViewData["Description"] = "LES Insights";
    ViewData["Keywords"] = "LES Insights";
    ViewData["CanonicalUrl"] = "/tr/insights";
    ViewData["AlternateUrls"] = new string[] { "/en/insights" };
}
@section styles{
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/insights.css">
    <style>
        .banner {
            position: relative;
            background-image: url('/images/LES5.jpg');
            /* Görselin yolu */
            background-size: cover;
            background-position: center;
            height: 300px;
            /* Yüksekliği isteğe göre ayarlayın */
            font-family: Arial, sans-serif;
            align-items: center;
            text-align: center;
        }

        .banner::before {
            content: '';
            background-color: rgba(0, 0, 0, 0.1);
            /* parlaklık azaltıcı katman */
            z-index: 1;
        }

        .banner-yazi {
            position: relative;
            font-size: 48px;
            font-weight: bold;
            padding-top: 178px;
            color: white;
        }

        .breadcrumb-1 a {
            color: white;
        }
    </style>
}
    
    <div class="banner">
        <div class="banner-yazi">LES-EXPO</div>
        <div class="breadcrumb-1">
            <a href="/tr">Ana Sayfa /</a>
            <a href="/tr/les-insights">LES Insights</a>
        </div>
    </div>

        <div class="container main-container">
            <div class="row">
                <!-- Sidebar -->
                <div class="col-md-3 sidebar-container">
                    <div class="sidebar">
                        <div class="sidebar-sticky">
                            <div class="sidebar-header p-3 mb-3 text-center">
                                <h3 class="" data-translate="hakkimizda.sidebar.mainTitle">LESEXPO</h3>
                                <p class="small mb-0" data-translate="hakkimizda.sidebar.subTitle">Insights
                                </p>
                            </div>
                            <ul class="nav flex-column">
                                <!-- Hakkımızda -->
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="collapse"
                                        data-bs-target="#hakkimizdaSubmenu" aria-expanded="true">
                                        <span class="menu-icon"><i class="fas fa-info-circle"></i></span>
                                        <span data-translate="hakkimizda.sidebar.aboutUs">LES Insights:</span>
                                    </a>
                                    <div class="collapse show" id="hakkimizdaSubmenu">
                                        <ul class="nav flex-column submenu">
                                            <li class="nav-item">
                                                <a class="nav-link" href="/tr/b2b-toplantilari">
                                                    <i class="fas fa-angle-right me-2"></i>
                                                    <span data-translate="hakkimizda.sidebar.bfmAbout">B2B
                                                        Toplantıları</span>
                                                </a>
                                            </li>
                                            <li class="nav-item">
                                                <a class="nav-link " href="/tr/les-insights">
                                                    <i class="fas fa-angle-right me-2"></i>
                                                    <span data-translate="hakkimizda.sidebar.presidentMessage">LES
                                                        Insights</span>
                                                </a>
                                            </li>
                                            <li class="nav-item">
                                                <a class="nav-link" href="/tr/les-experiences">
                                                    <i class="fas fa-angle-right me-2"></i>
                                                    <span data-translate="hakkimizda.sidebar.qualityPolicy">LES
                                                        Experiences</span>
                                                </a>
                                            </li>
                                        </ul>
                                    </div>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
                <!-- Main content -->
                <div class="content-area">
                    <section class="pharmaist-section">
                        <div class="pharmaist-text">
                            <h2 class="fw-bold fs-1">LES Insights:</h2>
                            <h4>LES-EXPO 2025 İstanbul: Dünyanın Yükünü Tasarlayan, Kaldıran, Taşıyan ve Taşıtanların
                                Buluşması! </h4>
                            <p class="light p-0">Yük mühendisliğinin geleceğini LES Insights'ta konuşuyoruz!</p>
                            <p>
                                <strong>LES Insights</strong>, yük mühendisliği hizmetlerini bağımsız ve multidisipliner
                                bir disiplin
                                olarak tanıtan profesyonel bir platform. Dialogues ve Spotlights oturumlarıyla, sektörün
                                en iyi uygulamalarını, yenilikçi teknolojilerini ve sürdürülebilirlik odaklı başarı
                                hikayelerini paylaşıyoruz.
                            </p>
                            <ul>
                                <li> <strong>Dialogues:</strong> Sektörün paydaşlarını bir araya getiren interaktif
                                    tartışmalar.</li>
                                <li><strong>Spotlights:</strong> İlham verici projeler ve uzmanlık hikayeleri.</li>
                            </ul>
                            <p>
                                Genç mühendislerden sektör liderlerine, herkes için bilgi, bağlantı ve ilham kaynağı
                                olan LES Insights, yakında açıklanacak programıyla yük mühendisliği hizmetlerinin
                                geleceğini şekillendirecek. Güncel program için <a href="#" class="link">Link</a>
                            </p>
                        </div>
                    </section>
                </div>
            </div>
        </div>
        <!-- Sidebar mobile toggle button -->
        <button class="sidebar-toggle-button d-md-none">
            <i class="fas fa-bars"></i>
        </button>


@section Scripts {
    <script src="/js/hakkimizda.js"></script>
    <script src="/js/main.js"></script>
}


