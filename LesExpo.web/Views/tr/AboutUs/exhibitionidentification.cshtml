
@{
    ViewData["Title"] = "Fuar Künyesi";
    ViewData["Description"] = "LES-EXPO 2025 - Yük Mühendisliği Hizmetleri Fuarı, 9-11 Eylül tarihlerinde İstanbul Fuar Merkezi'nde gerçekleşecek.";
    ViewData["Keywords"] = "LES-EXPO, fuar künyesi, yük mühendisliği, İstanbul Fuar Merkezi, fuar bilgileri";
}

@section styles{
        <link rel="stylesheet" href="/css/fuar-kunye.css">
        <style>
        .banner {
            position: relative;
            background-image: url('/images/LES5.jpg');
            /* Görselin yolu */
            background-size: cover;
            background-position: center;
            height: 300px;
            /* Yüksekliği isteğe göre ayarlayın */
            font-family: Arial, sans-serif;
            align-items: center;
            text-align: center;
        }

        .breadcrumb-1 a {
            color: white;
        }

        .sls {
            color: white;
        }
    </style>
}

    <div class="banner">
        <div class="banner-yazi">LES-EXPO</div>
        <div class="breadcrumb-1">
            <a href="index.html">Ana Sayfa / </a>
            <a href="fuar-kunyesi.html">Fuar Künyesi</a>
        </div>
    </div>


<div class="container main-container">
    <div class="row">
    <!-- Sidebar -->
        <partial name="Components/AboutUs/_SidebarHakkimizda" />
    <!-- Main content -->
    <div class="container-kunye col-md-9">
        <div class="main-content-kunye">
        <div class="header-text-kunye"></div>
        <div class="title-container-kunye">
            <div class="title-left-kunye">
            <h1>LES-EXPO</h1>
            </div>
        </div>

        <h2 class="kunye-h2">LES-EXPO-Yük Mühendisliği Hizmetleri Fuarı 9-11 Eylül Tarihlerinde İstanbul Fuar
            Merkezinde Sizlerle Buluşuyor!</h2>

        <p class="kunye-p">Les-Expo 2025, yük mühendisliği hizmetleri alanındaki en yeni gelişmeleri, teknolojileri
            ve yenilikçi çözümleri bir araya getiriyor.</p>

        <p class="kunye-p">Alanında uzman firmaların ve profesyonellerin katılımıyla gerçekleşecek olan bu fuar,
            sektördeki en son trendleri ve mühendislik hizmetlerinde devrim niteliğindeki yenilikleri keşfetmeniz için
            eşsiz bir fırsat sunacak.
            İstanbul Fuar Merkezi'nde 28 bin metrekare alanda Yük Mühendisliği hizmetlerinin sergileneceği fuar, hem
            ziyaretçilere hem de katılımcılara teknoloji ve trendlerin ön planda olduğu iş odaklı bir deneyim sunacak.
        </p>

        <h2>Fuar Takvimi</h2>

        <div class="calendar-grid-kunye">
            <div class="calendar-item-kunye">
            <div class="calendar-header-kunye">Salı</div>
            <div class="calendar-content-kunye">
                LESEXPO-Yük Mühendisliği Hizmetleri Fuarı
            </div>
            </div>

            <div class="calendar-item-kunye">
            <div class="calendar-header-kunye">Çarşamba</div>
            <div class="calendar-content-kunye">
                LESEXPO-Yük Mühendisliği Hizmetleri Fuarı
            </div>
            </div>

            <div class="calendar-item-kunye">
            <div class="calendar-header-kunye">Perşembe</div>
            <div class="calendar-content-kunye">
                LESEXPO-Yük Mühendisliği Hizmetleri Fuarı
            </div>
            </div>
        </div>

        <div class="salon-info-kunye">

        </div>
        </div>

        <div class="sidebar-kunye">
        <h3>Fuar Künyesi</h3>

        <div class="info-item-kunye">
            <div class="info-title-kunye">Başlangıç Tarihi:</div>
            <div class="info-content-kunye">09.09.2025</div>
        </div>

        <div class="info-item-kunye">
            <div class="info-title-kunye">Bitiş Tarihi:</div>
            <div class="info-content-kunye">11.09.2025</div>
        </div>

        <div class="info-item-kunye">
            <div class="info-title-kunye">Fuar Konusu:</div>
            <div class="info-content-kunye">Yük Mühendisliği Hizmetleri</div>
        </div>

        <div class="info-item-kunye">
            <div class="info-title-kunye">Organizatör Firma:</div>
            <div class="info-content-kunye">KFA Fuarcılık A.Ş.</div>
        </div>

        <div class="info-item-kunye">
            <div class="info-title-kunye">Ziyaret Saatleri:</div>
            <div class="info-content-kunye">09:30-18:00</div>
        </div>

        <div class="info-item-kunye">
            <div class="info-title-kunye">Fuar Alanı:</div>
            <div class="info-content-kunye">İstanbul Fuar Merkezi</div>
        </div>

        </div>
    </div>
    </div>
</div>

        <!-- Sidebar mobile toggle button -->
        <button class="sidebar-toggle-button d-md-none">
            <i class="fas fa-bars"></i>
        </button>

        @section Scripts {
    <script src="~/js/hakkimizda.js"></script>
}