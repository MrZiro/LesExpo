              </div>

              <div class="card-nze">
                <div class="icon-nze">
                  <i class="fa-solid fa-wind"></i>
                </div>
                <p class="card-text-nze">Yenilenebilir Enerji Şirketleri</p>
              </div>

              <div class="card-nze">
