@{
  ViewData["Title"] = "Exhibitor Profile";
  ViewData["Description"] = "LES-EXPO Katılımcı Profili - Yük Mühendisliği sektöründe faaliyet gösteren katılımcılarımızın profilleri ve fuarımıza katılım detayları hakkında bilgi edinin.";
  ViewData["Keywords"] = "Exhibitor Profile";

}
@section Styles{
  <link rel="stylesheet" href="/css/katilimci-profili.css">
    <style>
    .banner {
      position: relative;
      background-image: url('/images/LES2.jpg');
      /* Görselin yolu */
      background-size: cover;
      background-position: center;
      height: 300px;
      /* Yüksekliği isteğe göre ayarlayın */
      font-family: Arial, sans-serif;
      align-items: center;
      text-align: center;
    }

    .banner-yazi {
      position: relative;
      font-size: 48px;
      font-weight: bold;
      padding-top: 178px;
      color: white;
    }

    .breadcrumb-1 a {
      color: white;
    }
  </style>
}


  <div class="banner">
    <div class="banner-yazi">LES-EXPO</div>
    <div class="breadcrumb-1">
      <a href="/tr">Ana Sayfa /</a>
      <a href="/tr/katilimci-profili">Katılımcı Profili</a>
    </div>
  </div>

    <div class="container main-container">
      <div class="row">
        <!-- Sidebar -->
        <div class="col-md-3 sidebar-container">
          <div class="sidebar">
            <div class="sidebar-sticky">
              <div class="sidebar-header p-3 mb-3 text-center">
                <h3 class="text-white">LESEXPO</h3>
                <p class="text-white small mb-0 ">Katılımcı Profili</p>
              </div>
              <ul class="nav flex-column">
                <!-- Hakkımızda -->
                <li class="nav-item dropdown">
                  <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="collapse"
                    data-bs-target="#hakkimizdaSubmenu" aria-expanded="true">
                    <span class="menu-icon"><i class="fas fa-info-circle"></i></span>
                    <span data-translate="hakkimizda.sidebar.aboutUs">KATILIMCI</span>
                  </a>
                  <div class="collapse show" id="hakkimizdaSubmenu">
                    <ul class="nav flex-column submenu">
                      <li class="nav-item">
                        <a class="nav-link" href="/tr/katilimci-profili">
                          <i class="fas fa-angle-right me-2"></i>
                          <span data-translate="hakkimizda.sidebar.bfmAbout">Katılımcı Profili</span>
                        </a>
                      </li>
                      <li class="nav-item">
                        <a class="nav-link" href="/tr/on-kayit-formu">
                          <i class="fas fa-angle-right me-2"></i>
                          <span data-translate="hakkimizda.sidebar.ourTeam">Ön Kayıt Formu</span>
                        </a>
                      </li>
                      <li class="nav-item">
                        <a class="nav-link" href="/tr/neden-katilmalisiniz">
                          <i class="fas fa-angle-right me-2"></i>
                          <span data-translate="hakkimizda.sidebar.presidentMessage">Neden Katılmalısınız ?</span>
                        </a>
                      </li>
                      <li class="nav-item">
                        <a class="nav-link" href="/tr/katilimci-listesi">
                          <i class="fas fa-angle-right me-2"></i>
                          <span data-translate="hakkimizda.sidebar.qualityPolicy">Katılımcı Listesi 2025</span>
                        </a>
                      </li>
                    </ul>
                  </div>
                </li>
              </ul>
            </div>
          </div>
        </div>
        <!-- Main content -->
        <div class="container-nze content-area">
          <section>
            <h1 class="h1-ziyaretci ">LES-EXPO<br>KATILIMCI PROFİLİ</h1>
            <div class="card-grid-nze">
              <!-- Kart 1 -->
              <div class="card-nze">
                <div class="icon-nze">
                  <i class="fa-solid fa-industry"></i>
                </div>
                <p class="card-text-nze">Vinç Üretici ve Satıcıları</p>
              </div>

              <!-- Kart 2 -->
              <div class="card-nze">
                <div class="icon-nze">
                  <i class="fa-solid fa-truck-pickup"></i>
                </div>
                <p class="card-text-nze">Çekici Üretici ve Satıcıları</p>
              </div>

              <div class="card-nze">
                <div class="icon-nze">
                  <i class="fa-solid fa-truck-moving"></i>
                </div>
                <p class="card-text-nze"> Treyler Üretici ve Satıcıları</p>
              </div>

              <div class="card-nze">
                <div class="icon-nze">
                  <i class="fa-solid fa-toolbox"></i>
                </div>
                <p class="card-text-nze">Ekipman Üretici ve Satıcıları</p>
              </div>

              <div class="card-nze">
                <div class="icon-nze">
                  <i class="fa-solid fa-diagram-project"></i>
                </div>
