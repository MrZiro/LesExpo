                <div class="icon-nze">
                  <i class="fa-solid fa-ship"></i>
                </div>
                <p class="card-text-nze">Deniz Taşımacılık Şirketleri</p>
              </div>

              <!-- Kart 5 -->
              <div class="card-nze">
                <div class="icon-nze">
                  <i class="fa-solid fa-warehouse"></i>
                </div>
                <p class="card-text-nze">Liman İşletmecileri</p>
              </div>

              <!-- Kart 6 -->
              <div class="card-nze">
                <div class="icon-nze">
                  <i class="fa-solid fa-bolt"></i>
                </div>
                <p class="card-text-nze">Enerji Şirketleri </p>
              </div>

              <div class="card-nze">
                <div class="icon-nze">
