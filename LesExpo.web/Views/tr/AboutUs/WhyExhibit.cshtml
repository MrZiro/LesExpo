@{
  ViewData["Title"] = "Neden Katılmalısınız ?";
  ViewData["Description"] = "LES-EXPO Neden Katılmalısınız ? - LES-EXPO 2025'teki nedem Katılmalısınız ? hakkında bilgi edinin.";
  ViewData["Keywords"] = "LES-EXPO, Neden Katılmalısınız ?, Fair";

}
@section Styles{
  <link rel="stylesheet" href="/css/katilimci-profili.css">
  <link rel="stylesheet" href="/css/neden-katilmalisiniz.css">
    <style>
    .banner {
      position: relative;
      background-image: url('/images/LES2.jpg');
      /* Görselin yolu */
      background-size: cover;
      background-position: center;
      height: 300px;
      /* Yüksekliği isteğe göre ayarlayın */
      font-family: Arial, sans-serif;
      align-items: center;
      text-align: center;
    }

    .banner-yazi {
      position: relative;
      font-size: 48px;
      font-weight: bold;
      padding-top: 178px;
      color: white;
    }

    .breadcrumb-1 a {
      color: white;
    }
  </style>
}


  <div class="banner">
    <div class="banner-yazi">LES-EXPO</div>
    <div class="breadcrumb-1">
      <a href="/tr">Ana Sayfa /</a>
      <a href="/tr/neden-katilmalisiniz">Neden Katılmalısınız</a>
    </div>

  </div>

    <!-- Sidebar mobile toggle button -->
    <button class="sidebar-toggle-button d-md-none">
      <i class="fas fa-bars"></i>
    </button>

    <section id="nedenkatilmalisiniz" class="fuar-container">
      <div class="fuar-left">
        <img src="/images/textileshow-blog.png" alt="Rising City Görseli" class="fuar-image">
      </div>
      <div class="fuar-right">
        <p class="subtitle-3">LES-EXPO Yük Mühendisliği Hizmetleri Fuarı</p>
        <h1>NEDEN KATILMALISINIZ ?</h1>
        <p class="intro">
          Yük Mühendisliği Hizmetleri Fuarı, taşıyıcı sistem çözümleri, ağır yük mühendisliği, yapı güvenliği ve
          endüstriyel altyapı projeleri alanındaki son gelişmeleri bir araya getirerek sektöre yön veriyor...
        </p>
        <ul class="benefits">
          <li>Ağır yük mühendisliği alanındaki en yeni ürün, yazılım ve teknolojileri yakından inceleme fırsatı ✓</li>
          <li>Potansiyel iş ortakları ve müşterilerle birebir görüşmeler yaparak iş hacmini artırma ✓</li>
          <li>Marka bilinirliğini artırarak sektörde uzmanlığınızı ön plana çıkarma ✓</li>
          <li>Rakip firmaların çözümlerini gözlemleyerek stratejik avantajlar elde etme ✓</li>
          <li>Proje sahiplerinden ve mühendislerden doğrudan geri bildirim alma ve hizmetlerinizi geliştirme şansı ✓
          </li>
          <li>Uluslararası katılımcılarla bağlantı kurarak ihracat fırsatlarını değerlendirme </li>
        </ul>
        <a href="/tr/on-kayit-formu" class="btn-kp">Yerinizi Ayırtın</a>
      </div>

      <div class="features-nk">
        <div class="feature-item-nk">
          <div class="icon-container-nk">
            <i class="fas fa-handshake"></i>
          </div>
          <p>Sektör Liderleriyle<br>Buluşun</p>
        </div>

        <div class="feature-item-nk">
          <div class="icon-container-nk">
            <i class="fas fa-robot"></i>
          </div>
          <p>Yenilikçi<br>Teknolojiler</p>
        </div>

        <div class="feature-item-nk">
          <div class="icon-container-nk">
            <i class="fas fa-chalkboard-teacher"></i>
          </div>
          <p>Eğitim ve<br>Seminerler</p>
        </div>

        <div class="feature-item-nk">
          <div class="icon-container-nk">
            <i class="fas fa-globe-americas"></i>
          </div>
          <p>Global Ağ Kurma<br>İmkanları</p>
        </div>
      </div>
    </section>


@section Scripts{
  <script src="/js/hakkimizda.js"></script>
}
